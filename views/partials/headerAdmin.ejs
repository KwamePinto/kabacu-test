      <nav class="navbar navbar-expand-lg main-navbar sticky">
        <div class="form-inline mr-auto">
          <ul class="navbar-nav mr-3">
            <li><a href="#" data-toggle="sidebar" class="nav-link nav-link-lg collapse-btn">
              <i data-feather="align-justify"></i>
            </a></li>
            <li><a href="#" class="nav-link nav-link-lg fullscreen-btn">
              <i data-feather="maximize"></i>
            </a></li>
          </ul>
        </div>

        <ul class="navbar-nav navbar-right">

          <!-- ── Notifications ── -->
          <li class="dropdown dropdown-list-toggle">
            <a href="#" data-toggle="dropdown" class="nav-link notification-toggle nav-link-lg" id="notifToggle">
              <i data-feather="bell" class="bell"></i>
              <span class="badge headerBadge2" id="notifBadge" style="display:none;"></span>
            </a>
            <div class="dropdown-menu dropdown-list dropdown-menu-right pullDown" style="min-width:340px;">
              <div class="dropdown-header">
                Notifications
                <div class="float-right">
                  <a href="#" id="markAllRead" style="font-size:12px;">Mark All as Read</a>
                </div>
              </div>
              <div class="dropdown-list-content dropdown-list-icons" id="notifList">
                <div class="text-center p-3 text-muted" style="font-size:13px;">Loading…</div>
              </div>
              <div class="dropdown-footer text-center">
                <a href="/admin/product/view-transactions" style="font-size:13px;">
                  View All Transactions <i class="fas fa-chevron-right"></i>
                </a>
              </div>
            </div>
          </li>

          <!-- ── User dropdown ── -->
          <li class="dropdown">
            <a href="#" data-toggle="dropdown" class="nav-link dropdown-toggle nav-link-lg nav-link-user">
              <img alt="avatar" src="/admin/assets/img/user.png" class="user-img-radious-style">
              <span class="d-sm-none d-lg-inline-block ml-1" style="font-size:13px;font-weight:600;">
                <%= user ? user.username : 'Admin' %>
              </span>
            </a>
            <div class="dropdown-menu dropdown-menu-right pullDown">
              <div class="dropdown-title">
                <%= user ? user.username : 'Admin' %>
                <% if (user && user.role) { %>
                <br><small class="text-muted" style="font-size:11px;text-transform:capitalize;">
                  <%= user.role.replace(/_/g,' ') %>
                </small>
                <% } %>
              </div>
              <div class="dropdown-divider"></div>
              <a href="/admin/user/profile" class="dropdown-item has-icon">
                <i class="fas fa-user-circle"></i> My Profile
              </a>
              <div class="dropdown-divider"></div>
              <a href="/admin/user/logout" class="dropdown-item has-icon text-danger">
                <i class="fas fa-sign-out-alt"></i> Logout
              </a>
            </div>
          </li>

        </ul>
      </nav>

<script>
(function () {
  var badge    = document.getElementById('notifBadge');
  var list     = document.getElementById('notifList');
  var markAll  = document.getElementById('markAllRead');
  var loaded   = false;

  function timeAgo(date) {
    var diff = Math.floor((Date.now() - new Date(date)) / 1000);
    if (diff < 60)   return diff + 's ago';
    if (diff < 3600) return Math.floor(diff / 60) + 'm ago';
    if (diff < 86400) return Math.floor(diff / 3600) + 'h ago';
    return Math.floor(diff / 86400) + 'd ago';
  }

  function loadNotifications() {
    fetch('/admin/user/notifications')
      .then(function (r) { return r.json(); })
      .then(function (data) {
        var items = data.notifications || [];
        if (!items.length) {
          list.innerHTML = '<div class="text-center p-3 text-muted" style="font-size:13px;">No new notifications</div>';
          return;
        }
        badge.style.display = 'inline-block';
        badge.textContent   = items.length > 9 ? '9+' : items.length;
        list.innerHTML = items.map(function (n) {
          return '<a href="#" class="dropdown-item">' +
            '<span class="dropdown-item-icon ' + (n.color || 'bg-primary') + ' text-white">' +
              '<i data-feather="' + (n.icon || 'bell') + '"></i>' +
            '</span>' +
            '<span class="dropdown-item-desc">' + n.text +
              '<span class="time">' + timeAgo(n.time) + '</span>' +
            '</span>' +
          '</a>';
        }).join('');
        if (typeof feather !== 'undefined') feather.replace();
      })
      .catch(function () {
        list.innerHTML = '<div class="text-center p-3 text-muted" style="font-size:13px;">Could not load notifications</div>';
      });
  }

  // Load on dropdown open
  document.getElementById('notifToggle').addEventListener('click', function () {
    if (!loaded) { loadNotifications(); loaded = true; }
  });

  // Refresh every 2 minutes
  setInterval(function () { loaded = false; }, 120000);

  if (markAll) {
    markAll.addEventListener('click', function (e) {
      e.preventDefault();
      badge.style.display = 'none';
      list.innerHTML = '<div class="text-center p-3 text-muted" style="font-size:13px;">No new notifications</div>';
    });
  }
}());
</script>
