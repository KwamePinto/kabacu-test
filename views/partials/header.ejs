<header class="app-header">
  <div class="container">
    <div class="app-header__inner">

      <!-- Logo -->
      <a href="/" class="app-header__logo">
        <img src="/assets/images/new.PNG" alt="Data Mall">
      </a>

      <!-- Desktop nav links (hidden on mobile) -->
      <nav class="desktop-nav" aria-label="Main navigation">
        <a href="/" class="desktop-nav__link">Home</a>
        <a href="/category/data-category" class="desktop-nav__link">Data Bundles</a>
        <a href="/category/electronic-category" class="desktop-nav__link">Electronics</a>
        <a href="/category/automobile-category" class="desktop-nav__link">Automobiles</a>
        <a href="/category/course-category" class="desktop-nav__link">Courses</a>
        <a href="/category/p2p-category" class="desktop-nav__link">P2P</a>
      </nav>

      <!-- Actions -->
      <div class="app-header__actions">
        <button id="searchBtn" class="app-header__icon-btn" aria-label="Search">
          <i data-lucide="search"></i>
        </button>
        <% if (user) { %>
        <button id="openClaimModal" class="app-header__icon-btn app-header__icon-btn--bell" aria-label="Claim RP">
          <i data-lucide="bell"></i>
          <span class="app-header__notif-dot"></span>
        </button>
        <a href="/user-profile" class="app-header__icon-btn desktop-only" aria-label="My Account" title="My Account">
          <i data-lucide="user-circle-2"></i>
        </a>
        <% } else { %>
        <a href="/user/login" class="app-header__login-btn">
          <i data-lucide="log-in"></i>
          Log in
        </a>
        <% } %>
      </div>

    </div>
  </div>

  <!-- Search overlay — slides in from the right over the island/bar -->
  <div class="app-header__search-row" id="headerSearchRow">
    <button id="closeSearchBtn" class="app-header__icon-btn" aria-label="Close search">
      <i data-lucide="arrow-left"></i>
    </button>
    <div class="app-header__search-wrap">
      <i data-lucide="search"></i>
      <input type="text" id="headerSearchInput"
             class="app-header__search-input"
             placeholder="Search data bundles, networks..."
             autocomplete="off">
      <button id="clearSearchBtn" class="app-header__search-clear" aria-label="Clear">
        <i data-lucide="x"></i>
      </button>
    </div>
  </div>

</header>
