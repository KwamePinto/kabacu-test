<footer class="site-footer">
  <div class="container">
    <div class="site-footer__grid">

      <!-- Brand column -->
      <div>
        <div class="footer-brand__logo">
          <img src="/assets/images/new.PNG" alt="Data Mall">
        </div>
        <p class="footer-brand__desc">
          Nigeria's trusted marketplace for data bundles, electronics, automobiles, and courses. Best prices, instant delivery.
        </p>
        <div class="footer-socials">
          <a href="https://t.me/ctcofficialchannel" class="footer-social-link" target="_blank" rel="noopener" title="Telegram">
            <i data-lucide="send"></i>
          </a>
          <a href="https://web.facebook.com/ctcofficial01" class="footer-social-link" target="_blank" rel="noopener" title="Facebook">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 24 24"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
          </a>
          <a href="https://www.youtube.com/@CTCTUTORIAL" class="footer-social-link" target="_blank" rel="noopener" title="YouTube">
            <i data-lucide="youtube"></i>
          </a>
          <a href="https://www.instagram.com/ctcofficial1/" class="footer-social-link" target="_blank" rel="noopener" title="Instagram">
            <i data-lucide="instagram"></i>
          </a>
        </div>
      </div>

      <!-- Shop links -->
      <div>
        <h4 class="footer-col__title">Shop</h4>
        <div class="footer-col__links">
          <a href="/category/data-category" class="footer-col__link">Data Bundles</a>
          <a href="/category/electronic-category" class="footer-col__link">Electronics</a>
          <a href="/category/automobile-category" class="footer-col__link">Automobiles</a>
          <a href="/category/course-category" class="footer-col__link">Courses</a>
        </div>
      </div>

      <!-- Account links -->
      <div>
        <h4 class="footer-col__title">Account</h4>
        <div class="footer-col__links">
          <% if (user) { %>
          <a href="/user-profile" class="footer-col__link">My Profile</a>
          <a href="/my-wallet" class="footer-col__link">My Wallet</a>
          <a href="/history" class="footer-col__link">Order History</a>
          <a href="/user/logout" class="footer-col__link">Logout</a>
          <% } else { %>
          <a href="/user/login" class="footer-col__link">Sign In</a>
          <a href="/user/signup" class="footer-col__link">Register</a>
          <% } %>
        </div>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="footer-col__title">Contact</h4>
        <div class="footer-contact-item">
          <i data-lucide="mail"></i>
          <span>info@creativetimecenter.com</span>
        </div>
        <div class="footer-contact-item">
          <i data-lucide="message-circle"></i>
          <span>creativetimescenter@gmail.com</span>
        </div>
        <div class="footer-contact-item" style="margin-top:8px;">
          <i data-lucide="clock"></i>
          <span>24/7 Support</span>
        </div>
      </div>

    </div>

    <div class="footer-bottom">
      <p class="footer-bottom__copy">
        &copy; <%= new Date().getFullYear() %> Creative Time Center. All rights reserved.
      </p>
    </div>
  </div>
</footer>
