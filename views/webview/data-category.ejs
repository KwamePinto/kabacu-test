<section class="category-page">
  <div class="container">

    <!-- Page header -->
    <div class="page-hero">
      <h1 class="page-hero__title">
        <i data-lucide="wifi"></i>
        Data Bundles
      </h1>
      <p class="page-hero__sub">Instant delivery to any number</p>
    </div>

    <!-- Network tabs -->
    <div class="tabs-bar network-tabs" id="networkTabs">
      <% let tabIdx = 0; %>
      <% for (let network in groupedProducts) { %>
      <button
        class="tab-btn network-tab-btn <%= tabIdx === 0 ? 'active' : '' %>"
        data-tab="net_<%= tabIdx %>"
      >
        <%= network %>
      </button>
      <% tabIdx++; %>
      <% } %>
    </div>

    <!-- Network panels -->
    <% let panelIdx = 0; %>
    <% for (let network in groupedProducts) { %>
    <div id="net_<%= panelIdx %>" class="tab-panel network-panel <%= panelIdx === 0 ? 'active' : '' %>">
      <div class="bundle-grid">
        <% groupedProducts[network].forEach(function(product) { %>
        <div class="bundle-card">
          <div class="bundle-card__img">
            <img src="<%= product.images[0] %>" alt="<%= network %>">
          </div>
          <div class="bundle-card__body">
            <span class="bundle-card__network"><%= network %></span>
            <h4 class="bundle-card__name">
              <%= product.dataDetails.plan_type %> · <%= product.dataDetails.plan_name %>
            </h4>
            <div class="bundle-card__rp">
              <i data-lucide="star"></i>
              <%= product.reward_point %> RP
            </div>
            <div class="bundle-card__footer">
              <span class="bundle-card__price">₦<%= product.dataDetails.amount %></span>
              <% if (user) { %>
              <button class="btn btn--primary btn--sm buy-btn" data-id="<%= product._id %>">
                <i data-lucide="shopping-cart"></i>
                Buy
              </button>
              <% } else { %>
              <a href="/user/login" class="btn btn--primary btn--sm">Buy</a>
              <% } %>
            </div>
          </div>
        </div>
        <% }) %>
      </div>
    </div>
    <% panelIdx++; %>
    <% } %>

    <!-- Pagination -->
    <div class="pagination">
      <% if (hasPrevPage) { %>
      <a href="/category/data-category?page=<%= prevPage %>" class="pagination__btn">
        <i data-lucide="chevron-left"></i>
      </a>
      <% } %>
      <% for (let i = 1; i <= pages; i++) { %>
      <a href="/category/data-category?page=<%= i %>"
         class="pagination__page <%= i == current ? 'active' : '' %>">
        <%= i %>
      </a>
      <% } %>
      <% if (hasNextPage) { %>
      <a href="/category/data-category?page=<%= nextPage %>" class="pagination__btn">
        <i data-lucide="chevron-right"></i>
      </a>
      <% } %>
    </div>

  </div>
</section>

<!-- Buy Modal -->
<div id="buyModal" class="modal-overlay" role="dialog" aria-modal="true">
  <div class="modal-box">
    <div class="modal-box__header">
      <h3 class="modal-title">Enter Phone Number</h3>
      <button class="modal-close" id="cancelBtn" aria-label="Close">
        <i data-lucide="x"></i>
      </button>
    </div>
    <p class="modal-subtitle">Enter the active number to receive the data bundle</p>
    <div class="form-group">
      <label class="form-label">Phone Number</label>
      <div class="input-wrapper">
        <i data-lucide="phone"></i>
        <input type="text" id="phoneInput" class="form-input" placeholder="e.g 08012345678" maxlength="11" inputmode="numeric">
      </div>
      <small id="phoneError" style="color:var(--color-error);display:none;margin-top:4px;">Phone number must be exactly 11 digits</small>
    </div>
    <div class="modal-actions">
      <button id="checkoutBtn" class="btn btn--primary btn--full">
        <i data-lucide="arrow-right"></i>
        Proceed to Checkout
      </button>
    </div>
  </div>
</div>

<script>
// ── Tab switching ──
document.querySelectorAll('.network-tab-btn').forEach(btn => {
  btn.addEventListener('click', function() {
    document.querySelectorAll('.network-tab-btn').forEach(b => b.classList.remove('active'));
    document.querySelectorAll('.network-panel').forEach(p => p.classList.remove('active'));
    this.classList.add('active');
    document.getElementById(this.dataset.tab).classList.add('active');
  });
});

// ── Buy modal ──
let selectedPackageId = null;

document.querySelectorAll('.buy-btn').forEach(btn => {
  btn.addEventListener('click', function(e) {
    e.preventDefault();
    selectedPackageId = this.dataset.id;
    document.getElementById('buyModal').classList.add('open');
  });
});

document.getElementById('cancelBtn').addEventListener('click', () => {
  document.getElementById('buyModal').classList.remove('open');
});

document.getElementById('buyModal').addEventListener('click', function(e) {
  if (e.target === this) this.classList.remove('open');
});

const phoneInput = document.getElementById('phoneInput');
const phoneError = document.getElementById('phoneError');

phoneInput.addEventListener('input', function() {
  this.value = this.value.replace(/\D/g, '').slice(0, 11);
});

document.getElementById('checkoutBtn').addEventListener('click', async () => {
  const phone = phoneInput.value.trim();
  if (!/^\d{11}$/.test(phone)) {
    phoneError.style.display = 'block';
    phoneError.innerText = 'Phone number must be exactly 11 digits';
    return;
  }
  phoneError.style.display = 'none';
  const productId = selectedPackageId;
  if (!productId) { Swal.fire({ icon: 'error', text: 'No product selected' }); return; }
  try {
    const res = await fetch('/checkout/initiate', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ packageId: productId, phone })
    });
    const data = await res.json();
    if (data.success) {
      window.location.href = '/checkout';
    } else {
      Swal.fire({ icon: 'error', text: data.message || 'Something went wrong' });
    }
  } catch (err) {
    Swal.fire({ icon: 'error', text: 'Network error' });
  }
});
</script>
