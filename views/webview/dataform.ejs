<section class="auth-page">
  <div class="auth-card" style="max-width:560px;">
    <h1 class="auth-card__title">Data Form</h1>
    <form action="#" class="auth-form">
      <div class="form-group">
        <label class="form-label">Select</label>
        <div class="input-wrapper">
          <i data-lucide="list"></i>
          <select class="form-input form-select">
            <option>Sample</option>
            <option>Sample</option>
          </select>
        </div>
      </div>
      <div class="form-group">
        <label class="form-label">Email address</label>
        <div class="input-wrapper">
          <i data-lucide="mail"></i>
          <input type="email" name="email" class="form-input" placeholder="Email Address">
        </div>
      </div>
      <div class="form-group">
        <label class="form-label">Phone number</label>
        <div class="input-wrapper">
          <i data-lucide="phone"></i>
          <input type="tel" name="phone" class="form-input" placeholder="Phone Number">
        </div>
      </div>
      <div class="form-group">
        <label class="form-label">Message</label>
        <textarea name="mes" rows="5" class="form-input" placeholder="Leave a message" style="height:auto;padding-top:12px;"></textarea>
      </div>
      <button type="submit" class="btn btn--primary btn--full btn--lg">Send Message</button>
    </form>
  </div>
</section>
