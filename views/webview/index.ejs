<script>
/* ── Tab indicator ─────────────────────────────────────── */
function moveTabIndicator(tab) {
  var indicator = document.getElementById('tabIndicator');
  var btn = document.getElementById(tab === 'home' ? 'tabHome' : 'tabCategory');
  if (!indicator || !btn) return;
  indicator.style.left  = btn.offsetLeft + 'px';
  indicator.style.width = btn.offsetWidth + 'px';
}

/* ── Tab switching ─────────────────────────────────────── */
function switchTab(tab) {
  var isHome  = tab === 'home';
  var showEl  = document.getElementById(isHome ? 'homeContent' : 'categoryContent');
  var hideEl  = document.getElementById(isHome ? 'categoryContent' : 'homeContent');

  hideEl.style.display = 'none';
  hideEl.classList.remove('tab-entering');

  showEl.style.display = '';
  showEl.classList.remove('tab-entering');
  void showEl.offsetWidth;
  showEl.classList.add('tab-entering');

  document.getElementById('tabHome').classList.toggle('active', isHome);
  document.getElementById('tabCategory').classList.toggle('active', !isHome);

  moveTabIndicator(tab);
  lucide.createIcons();
}

// Initialise indicator on page load (no transition on first paint)
(function() {
  var indicator = document.getElementById('tabIndicator');
  if (indicator) indicator.style.transition = 'none';
  moveTabIndicator('home');
  setTimeout(function() {
    if (indicator) indicator.style.transition = '';
  }, 50);
})();

/* ── Carousel ─────────────────────────────────────────── */
(function() {
  var slides  = document.querySelectorAll('.promo-slide');
  var dots    = document.querySelectorAll('#promoDots .promo-dot');
  var current = 0;
  var timer;

  var slideData = [
    { title: 'Reward Points on Every Purchase',  sub: 'Collect reward points on every order and redeem them for free data.' },
    { title: 'Top Up Any Network Instantly',     sub: 'MTN · Airtel · Glo · 9Mobile — always available at the best prices.' },
    { title: 'Data Delivered in Seconds',        sub: 'Fast, instant delivery to any Nigerian network. Buy once, connect instantly.' },
    { title: 'Shop Phones, Gadgets & More',      sub: 'A trusted marketplace — secure trades, best deals and easy exchange.' },
    { title: 'Buy Data Bundles in Seconds',      sub: 'Fast, reliable plans at the best prices. Shop your network now.' }
  ];

  function updateHeroHeader(idx) {
    var titleEl = document.getElementById('heroTitle');
    var subEl   = document.getElementById('heroSub');
    if (titleEl) titleEl.textContent = slideData[idx].title;
    if (subEl)   subEl.textContent   = slideData[idx].sub;
  }

  function go(n) {
    var titleEl = document.getElementById('heroTitle');
    var subEl   = document.getElementById('heroSub');

    /* fade out heading text */
    if (titleEl) titleEl.style.opacity = '0';
    if (subEl)   subEl.style.opacity   = '0';

    slides[current].classList.remove('active');
    dots[current].classList.remove('promo-dot--active');
    current = (n + slides.length) % slides.length;
    slides[current].classList.add('active');
    dots[current].classList.add('promo-dot--active');

    /* update text mid-transition then fade back in */
    setTimeout(function() {
      updateHeroHeader(current);
      if (titleEl) titleEl.style.opacity = '';
      if (subEl)   subEl.style.opacity   = '';
    }, 280);
  }

  function restart() {
    clearInterval(timer);
    timer = setInterval(function() { go(current + 1); }, 4500);
  }

  dots.forEach(function(dot, i) {
    dot.addEventListener('click', function() { go(i); restart(); });
  });

  restart();
})();

/* ── Cat-browse scroll-reveal ─────────────────────────── */
(function() {
  var heading = document.querySelector('.cat-browse__heading');
  var grid    = document.querySelector('.cat-browse__grid');
  if (!grid || !window.IntersectionObserver) return;

  var io = new IntersectionObserver(function(entries) {
    entries.forEach(function(entry) {
      if (!entry.isIntersecting) return;
      if (entry.target === heading && heading) {
        heading.classList.add('revealed');
      } else {
        entry.target.querySelectorAll('.cat-browse__card').forEach(function(card) {
          card.classList.add('revealed');
        });
        io.unobserve(entry.target);
      }
    });
  }, { threshold: 0.15 });

  if (heading) io.observe(heading);
  io.observe(grid);

  lucide.createIcons();
})();

/* ── Hero background watermark pattern ───────────────── */
(function() {
  if (window.innerWidth < 768) return;
  var el = document.getElementById('heroBgPattern');
  if (!el) return;
  var words = ['Data', 'MTN', 'Airtel', 'Glo', '9Mobile', 'Electronics', 'Courses', 'Automobiles'];
  el.textContent = (words.join(' · ') + ' · ').repeat(30);
})();

/* ── Hero transparent header (desktop only) ──────────── */
(function() {
  if (window.innerWidth < 768) return;
  var header = document.querySelector('.app-header');
  var hero   = document.querySelector('.hero-section');
  var main   = document.querySelector('.page-main');
  if (!header || !hero) return;

  /* Remove page-main top gap so hero sits under the fixed bar */
  if (main) main.style.paddingTop = '0';

  function sync() {
    var bottom = hero.getBoundingClientRect().bottom;
    if (bottom > 10) {
      header.classList.add('hero-transparent');
    } else {
      header.classList.remove('hero-transparent');
    }
  }

  sync();
  window.addEventListener('scroll', sync, { passive: true });

  /* Restore on resize back to mobile */
  window.addEventListener('resize', function() {
    if (window.innerWidth < 768) {
      header.classList.remove('hero-transparent');
      if (main) main.style.paddingTop = '';
    } else {
      if (main) main.style.paddingTop = '0';
      sync();
    }
  }, { passive: true });
})();

/* ── Buy modal ────────────────────────────────────────── */
var selectedPackageId = null;

document.querySelectorAll('.buy-btn').forEach(function(btn) {
  btn.addEventListener('click', function(e) {
    e.preventDefault();
    e.stopPropagation();
    selectedPackageId = this.dataset.id;
    document.getElementById('buyModal').classList.add('open');
  });
});

document.getElementById('cancelBtn').addEventListener('click', function() {
  document.getElementById('buyModal').classList.remove('open');
});

document.getElementById('buyModal').addEventListener('click', function(e) {
  if (e.target === this) this.classList.remove('open');
});

var phoneInput = document.getElementById('phoneInput');
var phoneError = document.getElementById('phoneError');

phoneInput.addEventListener('input', function() {
  this.value = this.value.replace(/\D/g, '').slice(0, 11);
});

document.getElementById('checkoutBtn').addEventListener('click', async function() {
  var phone = phoneInput.value.trim();
  if (!/^\d{11}$/.test(phone)) { phoneError.style.display = 'block'; return; }
  phoneError.style.display = 'none';
  if (!selectedPackageId) { Swal.fire({ icon: 'error', text: 'No product selected' }); return; }
  try {
    var res  = await fetch('/checkout/initiate', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ packageId: selectedPackageId, phone: phone })
    });
    var data = await res.json();
    if (data.success) {
      window.location.href = '/checkout';
    } else {
      Swal.fire({ icon: 'error', text: data.message || 'Something went wrong' });
    }
  } catch (err) {
    Swal.fire({ icon: 'error', text: 'Network error' });
  }
});
</script>
