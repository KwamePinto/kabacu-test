<script>
  const successMsg = <%- JSON.stringify(success_msg) %>;
  const errorMsg   = <%- JSON.stringify(error_msg) %>;
  if (successMsg && successMsg.length > 0) Swal.fire({ icon: 'success', text: successMsg[0] });
  if (errorMsg && errorMsg.length > 0) Swal.fire({ icon: 'error', text: errorMsg[0] });
</script>

<section class="auth-page">
  <div class="auth-card">
    <div class="auth-card__logo">
      <img src="/assets/images/new.PNG" alt="Data Mall">
    </div>

    <h1 class="auth-card__title">Set new password</h1>
    <p class="auth-card__sub">Choose a strong password for your account</p>

    <form action="/user/profile-change-password-new" method="post" class="auth-form">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">

      <div class="form-group">
        <label class="form-label">New password</label>
        <div class="input-wrapper input-wrapper--pw">
          <i data-lucide="lock"></i>
          <input type="password" name="newPassword" id="newPassword" class="form-input" placeholder="At least 6 characters" required minlength="6" autofocus>
          <button type="button" class="pw-toggle" data-target="newPassword" aria-label="Toggle password visibility">
            <i data-lucide="eye" class="pw-toggle__show"></i>
            <i data-lucide="eye-off" class="pw-toggle__hide" style="display:none;"></i>
          </button>
        </div>
        <div class="pw-strength" id="pwStrength">
          <div class="pw-strength__segments">
            <span class="pw-strength__seg"></span>
            <span class="pw-strength__seg"></span>
            <span class="pw-strength__seg"></span>
            <span class="pw-strength__seg"></span>
          </div>
          <span class="pw-strength__label" id="pwStrengthLabel"></span>
        </div>
      </div>

      <div class="form-group">
        <label class="form-label">Confirm new password</label>
        <div class="input-wrapper input-wrapper--pw">
          <i data-lucide="lock"></i>
          <input type="password" name="confirmPassword" id="confirmPassword" class="form-input" placeholder="Repeat your password" required minlength="6">
          <button type="button" class="pw-toggle" data-target="confirmPassword" aria-label="Toggle password visibility">
            <i data-lucide="eye" class="pw-toggle__show"></i>
            <i data-lucide="eye-off" class="pw-toggle__hide" style="display:none;"></i>
          </button>
        </div>
      </div>

      <button type="submit" class="btn btn--primary btn--full btn--lg">Update Password</button>
    </form>
  </div>
</section>

<script>
(function () {
  /* ── Password visibility toggles ── */
  document.querySelectorAll('.pw-toggle').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var input = document.getElementById(btn.getAttribute('data-target'));
      if (!input) return;
      var show = input.type === 'password';
      input.type = show ? 'text' : 'password';
      btn.querySelector('.pw-toggle__show').style.display = show ? 'none' : '';
      btn.querySelector('.pw-toggle__hide').style.display = show ? '' : 'none';
    });
  });

  /* ── Password strength meter ── */
  var input = document.getElementById('newPassword');
  var meter = document.getElementById('pwStrength');
  var label = document.getElementById('pwStrengthLabel');
  var levels = ['', 'pw-strength--weak', 'pw-strength--fair', 'pw-strength--good', 'pw-strength--strong'];
  var names  = ['', 'Weak', 'Fair', 'Good', 'Strong'];

  function score(pw) {
    if (!pw) return 0;
    var s = 0;
    if (pw.length >= 8)           s++;
    if (pw.length >= 12)          s++;
    if (/[A-Z]/.test(pw))         s++;
    if (/[0-9]/.test(pw))         s++;
    if (/[^A-Za-z0-9]/.test(pw))  s++;
    if (s <= 1) return 1;
    if (s === 2) return 2;
    if (s === 3) return 3;
    return 4;
  }

  if (input && meter && label) {
    input.addEventListener('input', function () {
      var lvl = input.value.length ? score(input.value) : 0;
      meter.classList.toggle('visible', lvl > 0);
      levels.forEach(function (c) { if (c) meter.classList.remove(c); });
      if (lvl > 0) meter.classList.add(levels[lvl]);
      label.textContent = names[lvl] || '';
    });
  }
})();
</script>