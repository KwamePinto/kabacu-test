<script>
  const successMsg = <% - JSON.stringify(success_msg) %>;
  const errorMsg = <% - JSON.stringify(error_msg) %>;
  if (successMsg.length > 0) Swal.fire({ icon: 'success', text: successMsg[0] });
  if (errorMsg.length > 0) Swal.fire({ icon: 'error', text: errorMsg[0] });
</script>

<section class="wallet-page">
  <div class="container">

    <!-- Page hero -->
    <div class="page-hero">
      <h1 class="page-hero__title">
        <i data-lucide="wallet"></i>
        My Wallet
      </h1>
      <p class="page-hero__sub">Manage your balances and fund your account</p>
    </div>

    <!-- Balance cards -->
    <div class="balance-grid">
      <div class="balance-card balance-card--naira">
        <div class="balance-card__icon"><i data-lucide="banknote"></i></div>
        <div class="balance-card__body">
          <span class="balance-card__label">Naira Balance</span>
          <span class="balance-card__amount">
            ₦<%= wallet && wallet.balances ? wallet.balances.NAIRA.toFixed(2) : '0.00' %>
          </span>
        </div>
      </div>
      <div class="balance-card balance-card--btt">
        <div class="balance-card__icon"><i data-lucide="zap"></i></div>
        <div class="balance-card__body">
          <span class="balance-card__label">BTT Balance</span>
          <span class="balance-card__amount">
            <%= wallet && wallet.balances ? wallet.balances.BTT.toFixed(2) : '0.00' %> BTT
          </span>
        </div>
      </div>
      <div class="balance-card balance-card--usdt">
        <div class="balance-card__icon"><i data-lucide="dollar-sign"></i></div>
        <div class="balance-card__body">
          <span class="balance-card__label">USDT Balance</span>
          <span class="balance-card__amount">
            $<%= wallet && wallet.balances ? wallet.balances.USDT.toFixed(2) : '0.00' %>
          </span>
        </div>
      </div>
      <div class="balance-card balance-card--rp">
        <div class="balance-card__icon"><i data-lucide="star"></i></div>
        <div class="balance-card__body">
          <span class="balance-card__label">Reward Points</span>
          <span class="balance-card__amount">
            <%= wallet && wallet.balances ? wallet.balances.RP.toFixed(2) : '0.00' %> RP
          </span>
        </div>
      </div>
    </div>

    <!-- Action cards -->
    <div class="wallet-actions">

      <!-- BTT/RP/USDT Top-up via OTP -->
      <div class="action-card">
        <h3 class="action-card__title">
          <i data-lucide="arrow-up-circle"></i>
          Top-Up Wallet
        </h3>
        <p class="action-card__desc">Fund BTT, RP, or USDT via BitToken OTP</p>

        <div class="form-group">
          <label class="form-label">Wallet Type</label>
          <div class="input-wrapper">
            <i data-lucide="layers"></i>
            <select id="walletType" class="form-input form-select">
              <option value="">Select wallet type</option>
              <option value="BTT">BTT</option>
              <option value="RP">RP</option>
              <option value="USDT">USDT</option>
            </select>
          </div>
        </div>

        <div class="form-group">
          <label class="form-label">Amount</label>
          <div class="input-wrapper">
            <i data-lucide="hash"></i>
            <input type="number" id="amount" class="form-input" placeholder="Enter amount">
          </div>
        </div>

        <button id="startTopup" class="btn btn--primary btn--full">
          <i data-lucide="send"></i>
          Request OTP
        </button>

        <div id="otpBox" class="otp-section" style="display:none;">
          <div class="form-group" style="margin-top:16px;">
            <label class="form-label">OTP Code</label>
            <div class="input-wrapper">
              <i data-lucide="shield"></i>
              <input type="text" id="otp" class="form-input" placeholder="Enter OTP from Telegram">
            </div>
          </div>
          <button id="confirmTopup" class="btn btn--primary btn--full">
            <i data-lucide="check"></i>
            Confirm Top-Up
          </button>
        </div>

        <p class="action-note">
          <i data-lucide="info"></i>
          OTP is sent to your Telegram wallet bot
        </p>
      </div>

      <!-- USDT to Naira conversion -->
      <div class="action-card">
        <h3 class="action-card__title">
          <i data-lucide="refresh-cw"></i>
          Convert USDT to Naira
        </h3>
        <p class="action-card__desc">Instantly convert your USDT balance to NGN</p>

        <div class="form-group">
          <label class="form-label">From</label>
          <div class="input-wrapper">
            <i data-lucide="dollar-sign"></i>
            <input type="text" value="USDT" class="form-input" disabled>
          </div>
        </div>

        <div class="form-group">
          <label class="form-label">Amount (USDT)</label>
          <div class="input-wrapper">
            <i data-lucide="hash"></i>
            <input type="number" id="usdtAmount" class="form-input" placeholder="Enter USDT amount">
          </div>
        </div>

        <div class="form-group">
          <label class="form-label">You will receive (₦)</label>
          <div class="input-wrapper">
            <i data-lucide="banknote"></i>
            <input type="text" id="nairaAmount" class="form-input" placeholder="₦0.00" readonly>
          </div>
        </div>

        <div class="conversion-preview" id="conversionPreview" style="display:none;">
          <span id="conversionRate"></span>
        </div>

        <button id="convertBtn" class="btn btn--primary btn--full">
          <i data-lucide="arrow-right"></i>
          Convert Now
        </button>
      </div>

      <!-- PalmPay fund Naira wallet -->
      <div class="action-card">
        <h3 class="action-card__title">
          <i data-lucide="credit-card"></i>
          Fund Naira Wallet
        </h3>
        <p class="action-card__desc">Pay securely via PalmPay</p>

        <div class="form-group">
          <label class="form-label">Payment Method</label>
          <div class="input-wrapper">
            <i data-lucide="credit-card"></i>
            <input type="text" value="PalmPay" class="form-input" disabled>
          </div>
        </div>

        <div class="form-group">
          <label class="form-label">Amount (₦)</label>
          <div class="input-wrapper">
            <i data-lucide="hash"></i>
            <input type="number" id="palmpayAmount" class="form-input" placeholder="Enter amount" min="100">
          </div>
        </div>

        <button id="palmpayBtn" class="btn btn--primary btn--full">
          <i data-lucide="external-link"></i>
          Pay with PalmPay
        </button>

        <p class="action-note">
          <i data-lucide="info"></i>
          You will be redirected to PalmPay secure checkout
        </p>
      </div>

    </div>
  </div>
</section>

<script>
  let topupId = null;

  // ── BTT/RP/USDT Top-up ──────────────────────────────────
  document.getElementById('startTopup').addEventListener('click', async () => {
    const amount = document.getElementById('amount').value;
    const balanceType = document.getElementById('walletType').value;
    const res = await fetch('/wallet/start-topup', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': '<%= csrfToken %>' },
      body: JSON.stringify({ amount, balanceType })
    });
    const data = await res.json();
    if (data.success) {
      topupId = data.topupId;
      document.getElementById('otpBox').style.display = 'block';
      Swal.fire({ icon: 'warning', text: 'OTP Sent to your Telegram bot' });
    } else {
      Swal.fire({ icon: 'error', text: data.message });
    }
  });

  document.getElementById('confirmTopup').addEventListener('click', async () => {
    const otp = document.getElementById('otp').value;
    const res = await fetch('/wallet/confirm-topup', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': '<%= csrfToken %>' },
      body: JSON.stringify({ otp, topupId })
    });
    const data = await res.json();
    if (data.success) {
      Swal.fire({ icon: 'success', text: 'Wallet funded successfully' });
      setTimeout(() => location.reload(), 1500);
    } else {
      Swal.fire({ icon: 'error', text: data.message });
    }
  });

  // ── USDT preview ──────────────────────────────────────────
  document.getElementById('usdtAmount').addEventListener('input', async function () {
    const amount = this.value;
    if (!amount || amount <= 0) {
      document.getElementById('nairaAmount').value = '';
      document.getElementById('conversionPreview').style.display = 'none';
      return;
    }
    try {
      const res = await fetch('/wallet/preview-conversion', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': '<%= csrfToken %>' },
        body: JSON.stringify({ amount })
      });
      const data = await res.json();
      if (data.success) {
        document.getElementById('nairaAmount').value = '₦' + Number(data.nairaAmount).toLocaleString();
        document.getElementById('conversionPreview').style.display = 'block';
      }
    } catch (err) { console.log(err); }
  });

  // ── USDT convert ──────────────────────────────────────────
  document.getElementById('convertBtn').addEventListener('click', async () => {
    const amount = document.getElementById('usdtAmount').value;
    if (!amount || amount <= 0) {
      Swal.fire({ icon: 'warning', text: 'Enter valid amount' });
      return;
    }
    try {
      const res = await fetch('/wallet/convert-usdt', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': '<%= csrfToken %>' },
        body: JSON.stringify({ amount })
      });
      const data = await res.json();
      if (data.success) {
        document.getElementById('nairaAmount').value = '₦' + data.nairaAmount.toLocaleString();
        Swal.fire({ icon: 'success', text: 'Conversion successful' });
        setTimeout(() => location.reload(), 1500);
      } else {
        Swal.fire({ icon: 'error', text: data.message });
      }
    } catch (err) {
      Swal.fire({ icon: 'warning', text: 'Something went wrong' });
    }
  });

  // ── PalmPay ───────────────────────────────────────────────
  document.getElementById('palmpayBtn').addEventListener('click', async () => {
    const amount = document.getElementById('palmpayAmount').value;
    //const conversion = amount * 100;
    if (!amount) {
      Swal.fire({ icon: 'warning', text: 'Enter amount' });
      return;
    }
    try {
      const response = await fetch('/palmpay/create', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': '<%= csrfToken %>' },
        body: JSON.stringify({ amount })
      });
      const data = await response.json();
      if (data.success) {
        window.location.href = data.paymentUrl;
      } else {
        Swal.fire({ icon: 'warning', text: data.message || 'Payment failed' });
      }
    } catch (error) {
      Swal.fire({ icon: 'warning', text: 'Something went wrong' });
    }
  });
</script>