   <script>

    let topupId = null;

document.getElementById('startTopup').addEventListener('click', async () => {

    const amount = document.getElementById('amount').value;
    const balanceType = document.getElementById('walletType').value;

    const res = await fetch('/wallet/start-topup', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ amount, balanceType })
    });

    const data = await res.json();

    if (data.success) {
        topupId = data.topupId;
        document.getElementById('otpBox').style.display = 'block';
        alert('OTP sent');
    } else {
        alert(data.message);
    }
});


document.getElementById('confirmTopup').addEventListener('click', async () => {

    const otp = document.getElementById('otp').value;

    const res = await fetch('/wallet/confirm-topup', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ otp, topupId })
    });

    const data = await res.json();

    if (data.success) {
        alert('Wallet funded successfully');
        location.reload();
    } else {
        alert(data.message);
    }
});


const usdtInput =
    document.getElementById('usdtAmount');

usdtInput.addEventListener('input', async () => {

    const amount = usdtInput.value;

    // RESET
    if (!amount || amount <= 0) {

        document.getElementById('nairaAmount')
        .value = '';

        return;
    }

    try {

        const res = await fetch(
            '/wallet/preview-conversion',
            {
                method: 'POST',

                headers: {
                    'Content-Type': 'application/json'
                },

                body: JSON.stringify({
                    amount
                })
            }
        );

        const data = await res.json();

        if (data.success) {

            document.getElementById('nairaAmount')
            .value =
                '₦' +
                Number(data.nairaAmount)
                .toLocaleString();

        }

    } catch (err) {

        console.log(err);
    }

});





document.getElementById('convertBtn')
.addEventListener('click', async () => {

    const amount =
        document.getElementById('usdtAmount').value;

    if (!amount || amount <= 0) {

        alert('Enter valid amount');

        return;
    }

    try {

        const res = await fetch('/wallet/convert-usdt', {

            method: 'POST',

            headers: {
                'Content-Type': 'application/json'
            },

            body: JSON.stringify({
                amount
            })
        });

        const data = await res.json();

        if (data.success) {

            document.getElementById('nairaAmount')
            .value =
                '₦' + data.nairaAmount.toLocaleString();

            alert('Conversion successful');

            // OPTIONAL REFRESH
            setTimeout(() => {
                location.reload();
            }, 1000);

        } else {

            alert(data.message);
        }

    } catch (err) {

        console.log(err);

        alert('Something went wrong');
    }

});





document.getElementById('palmpayBtn').addEventListener('click', async () => {

    const amount =
        document
        .getElementById('palmpayAmount')
        .value;



    if (!amount) {

        alert(
            'Enter amount'
        );

        return;
    }

    


    try {

        const response =
            await fetch(

                '/palmpay/create',

                {

                    method: 'POST',

                    headers: {

                        'Content-Type':
                            'application/json'
                    },

                    body:
                        JSON.stringify({
                            amount
                        })
                }
            );



        const data =
            await response.json();

        console.log(data);



        if (data.success) {

            window.location.href =
                data.paymentUrl;

        } else {

            alert(
                data.message ||
                'Payment failed'
            );
        }

    } catch (error) {

        console.log(error);

        alert(
            'Something went wrong'
        );
    }
});

// ✅ Wallet payment (NEW LOGIC)
document.getElementById('walletBtn').addEventListener('click', async () => {
    try {
        const res = await fetch('/wallet/pay', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ productId: selectedProductId }) // ✅ send productId
        });

        const data = await res.json();

        if (data.success) {
            alert('✅ Payment successful');
            modal.style.display = 'none';
            location.reload();
        } else {
            alert(data.message);
        }

    } catch (error) {
        console.log(error);
        alert('Payment error');
    }
});



