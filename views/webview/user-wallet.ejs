<style>

.form-row {

    display: grid;

    grid-template-columns: repeat(3, 1fr);

    gap: 20px;

    margin-top: 20px;
}

/* Each column */

.form-col {

    width: 100%;
}

/* Card styling */

.action-form {

    background: #fff;

    padding: 15px;

    border-radius: 10px;

    box-shadow: 0 2px 8px rgba(0,0,0,0.08);

    height: 100%;
}

/* INPUT STYLING */

.qty-input input,
.qty-input select {

    width: 100%;

    border: none;

    outline: none;

    background: transparent;

    font-size: 14px;
}

/* BUTTON FULL WIDTH */

.buttons .btn {

    width: 100%;
}

/* 📱 TABLET */

@media (max-width: 992px) {

    .form-row {

        grid-template-columns: 1fr 1fr;
    }
}

/* 📱 MOBILE */

@media (max-width: 768px) {

    .product-attribute {

        width: 100%;

        display: block;
    }

    .form-row {

        display: block !important;

        width: 100%;

        margin-top: 20px;
    }

    .form-col {

        width: 100% !important;

        margin-bottom: 20px;
    }
}

