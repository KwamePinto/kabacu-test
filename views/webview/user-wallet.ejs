<script>
  const successMsg = <% - JSON.stringify(success_msg) %>;
  const errorMsg = <% - JSON.stringify(error_msg) %>;
  if (successMsg.length > 0) Swal.fire({ icon: 'success', text: successMsg[0] });
  if (errorMsg.length > 0) Swal.fire({ icon: 'error', text: errorMsg[0] });
</script>

<section class="wallet-page">
  <div class="container">

    <!-- Back button -->
    <a href="/user-profile" class="back-btn">
      <i data-lucide="arrow-left"></i>
      Back to Profile
    </a>

    <!-- Page hero -->
    <div class="page-hero">
      <h1 class="page-hero__title">
        <i data-lucide="wallet"></i>
        My Wallet
      </h1>
      <p class="page-hero__sub">Manage your balances and fund your account</p>
    </div>

    <!-- Balance cards -->
    <div class="balance-grid">
      <div class="balance-card balance-card--naira">
        <div class="balance-card__icon"><i data-lucide="banknote"></i></div>
        <div class="balance-card__body">
          <span class="balance-card__label">Naira Balance</span>
          <span class="balance-card__amount">
            ₦<%= wallet && wallet.balances ? wallet.balances.NAIRA.toFixed(2) : '0.00' %>
          </span>
        </div>
      </div>
      <div class="balance-card balance-card--btt">
        <div class="balance-card__icon"><i data-lucide="zap"></i></div>
        <div class="balance-card__body">
          <span class="balance-card__label">BTT Balance</span>
          <span class="balance-card__amount">
            <%= wallet && wallet.balances ? wallet.balances.BTT.toFixed(2) : '0.00' %> BTT
          </span>
        </div>
      </div>
      <div class="balance-card balance-card--usdt">
        <div class="balance-card__icon"><i data-lucide="dollar-sign"></i></div>
        <div class="balance-card__body">
          <span class="balance-card__label">USDT Balance</span>
          <span class="balance-card__amount">
            $<%= wallet && wallet.balances ? wallet.balances.USDT.toFixed(2) : '0.00' %>
          </span>
        </div>
      </div>
      <div class="balance-card balance-card--rp">
        <div class="balance-card__icon"><i data-lucide="star"></i></div>
        <div class="balance-card__body">
          <span class="balance-card__label">Reward Points</span>
          <span class="balance-card__amount">
            <%= wallet && wallet.balances ? wallet.balances.RP.toFixed(2) : '0.00' %> RP
          </span>
        </div>
      </div>
    </div>

    <!-- Action cards -->
    <div class="wallet-actions">

      <!-- BTT/RP/USDT Top-up via OTP -->
      <div class="action-card">
        <h3 class="action-card__title">
          <i data-lucide="arrow-up-circle"></i>
          Top-Up Wallet
        </h3>
        <p class="action-card__desc">Fund BTT, or USDT via BitToken OTP</p>

        <div class="form-group">
          <label class="form-label">Wallet Type</label>
          <div class="input-wrapper">
            <i data-lucide="layers"></i>
            <select id="walletType" class="form-input form-select">
              <option value="">Select wallet type</option>
              <option value="BTT">BTT</option>
              <!-- <option value="RP">RP</option> -->
              <option value="USDT">USDT</option>
            </select>
          </div>
        </div>

        <div class="form-group">
          <label class="form-label">Amount</label>
          <div class="input-wrapper">
            <i data-lucide="hash"></i>
            <input type="number" id="amount" class="form-input" placeholder="Enter amount" step="0.01">
          </div>
        </div>

        <button id="startTopup" class="btn btn--primary btn--full">
          <i data-lucide="send"></i>
          Request OTP
        </button>

        <div id="otpBox" class="otp-section" style="display:none;">
          <div class="form-group" style="margin-top:16px;">
            <label class="form-label">OTP Code</label>
            <div class="input-wrapper">
              <i data-lucide="shield"></i>
              <input type="text" id="otp" class="form-input" placeholder="Enter OTP code">
            </div>
          </div>
          <button id="confirmTopup" class="btn btn--primary btn--full">
            <i data-lucide="check"></i>
            Confirm Top-Up
          </button>
        </div>

        <p class="action-note" id="otpDeliveryNote">
          <i data-lucide="info"></i>
          OTP is sent to your Telegram or WhatsApp wallet bot
        </p>
      </div>

      <!-- USDT to Naira conversion -->
      <div class="action-card">
        <h3 class="action-card__title">
          <i data-lucide="refresh-cw"></i>
          Convert USDT to Naira
        </h3>
        <p class="action-card__desc">Instantly convert your USDT balance to NGN</p>

        <div class="form-group">
          <label class="form-label">From</label>
          <div class="input-wrapper">
            <i data-lucide="dollar-sign"></i>
            <input type="text" value="USDT" class="form-input" disabled>
          </div>
        </div>

        <div class="form-group">
          <label class="form-label">Amount (USDT)</label>
          <div class="input-wrapper">
            <i data-lucide="hash"></i>
            <input type="number" id="usdtAmount" class="form-input" placeholder="Enter USDT amount">
          </div>
        </div>

        <div class="form-group">
          <label class="form-label">You will receive (₦)</label>
          <div class="input-wrapper">
            <i data-lucide="banknote"></i>
            <input type="text" id="nairaAmount" class="form-input" placeholder="₦0.00" readonly>
          </div>
        </div>

        <button id="convertBtn" class="btn btn--primary btn--full">
          <i data-lucide="arrow-right"></i>
          Convert Now
        </button>
      </div>

      <!-- Fund Naira Wallet -->
      <div class="action-card">
        <h3 class="action-card__title">
          <i data-lucide="credit-card"></i>
          Fund Naira Wallet
        </h3>
        <p class="action-card__desc">Choose a payment method and fund your Naira balance</p>

        <div class="form-group">
          <label class="form-label">Payment Method</label>
          <div class="input-wrapper">
            <i data-lucide="credit-card"></i>
            <select id="paymentMethod" class="form-input form-select">
              <option value="">Select payment method</option>
              <% if (paymentMethods && paymentMethods.length > 0) { %>
                <% paymentMethods.forEach(function(m) { %>
                  <option value="<%= m.name %>"><%= m.name %></option>
                <% }) %>
              <% } %>
            </select>
          </div>
        </div>

        <div class="form-group">
          <label class="form-label">Amount (₦)</label>
          <div class="input-wrapper">
            <i data-lucide="hash"></i>
            <input type="number" id="palmpayAmount" class="form-input" placeholder="Enter amount" min="100">
          </div>
        </div>

        <button id="palmpayBtn" class="btn btn--primary btn--full" disabled>
          <i data-lucide="external-link"></i>
          <span id="palmpayBtnText">Select a payment method</span>
        </button>

        <p class="action-note">
          <i data-lucide="info"></i>
          You will be redirected to the secure payment checkout
        </p>
      </div>

      <!-- Transfer RP to BitToken -->
      <div class="action-card">
        <h3 class="action-card__title">
          <i data-lucide="send"></i>
          Transfer RP to BitToken
        </h3>
        <p class="action-card__desc">Send your Reward Points to your BitToken account</p>

        <% if (user && !user.minerId) { %>
        <div style="background:#fff7ed;border:1px solid #fed7aa;border-radius:8px;padding:12px 14px;margin-bottom:16px;display:flex;align-items:flex-start;gap:10px;">
          <i data-lucide="alert-triangle" style="color:#f97316;flex-shrink:0;margin-top:2px;"></i>
          <div style="font-size:13px;color:#7c2d12;line-height:1.5;">
            <strong>Miner ID not set.</strong> You need to add your BitToken Miner ID to your profile before you can transfer RP.
            <br><a href="/user-profile" style="color:#f97316;font-weight:600;text-decoration:underline;">Go to Profile →</a>
          </div>
        </div>
        <% } %>

        <div class="form-group">
          <label class="form-label">RP Amount</label>
          <div class="input-wrapper">
            <i data-lucide="star"></i>
            <input type="number" id="rpTransferAmount" class="form-input" placeholder="Enter RP amount" min="1" step="1"
              <%= user && !user.minerId ? 'disabled' : '' %>>
          </div>
        </div>

        <p style="font-size:12px;color:#6b7280;margin:-8px 0 14px;">
          Available: <strong><%= wallet && wallet.balances ? wallet.balances.RP.toFixed(2) : '0.00' %> RP</strong>
        </p>

        <button id="transferRpBtn" class="btn btn--primary btn--full" <%= user && !user.minerId ? 'disabled' : '' %>>
          <i data-lucide="send"></i>
          Transfer to BitToken
        </button>

        <p class="action-note">
          <i data-lucide="info"></i>
          RP will be deducted from your wallet and credited to your BitToken account
        </p>
      </div>

    </div>
  </div>
</section>

<script>
  let topupId = null;

  const USDT_MIN = 0.50;

  // ── Wallet type selector: update amount constraints ─────
  document.getElementById('walletType').addEventListener('change', function () {
    const amountInput = document.getElementById('amount');
    if (this.value === 'USDT') {
      amountInput.min = USDT_MIN;
      amountInput.placeholder = 'Minimum 0.50 USDT';
    } else {
      amountInput.removeAttribute('min');
      amountInput.placeholder = 'Enter amount';
    }
    amountInput.value = '';
    amountInput.setCustomValidity('');
  });

  // ── Real-time USDT minimum enforcement ──────────────────
  document.getElementById('amount').addEventListener('input', function () {
    const balanceType = document.getElementById('walletType').value;
    if (balanceType !== 'USDT') return;
    const val = parseFloat(this.value);
    if (!isNaN(val) && val < USDT_MIN) {
      this.setCustomValidity('Minimum USDT top-up is 0.50');
      this.reportValidity();
    } else {
      this.setCustomValidity('');
    }
  });

  // ── BTT/RP/USDT Top-up ──────────────────────────────────
  document.getElementById('startTopup').addEventListener('click', async () => {
    const amountInput = document.getElementById('amount');
    const amount = parseFloat(amountInput.value);
    const balanceType = document.getElementById('walletType').value;

    if (!balanceType) {
      return Swal.fire({ icon: 'warning', text: 'Please select a wallet type.' });
    }

    if (isNaN(amount) || amount <= 0) {
      return Swal.fire({ icon: 'warning', text: 'Please enter a valid amount.' });
    }

    if (balanceType === 'USDT' && amount < USDT_MIN) {
      return Swal.fire({ icon: 'error', title: 'Amount too low', text: 'Minimum USDT top-up is 0.50.' });
    }

    const btn = document.getElementById('startTopup');
    btn.disabled = true;
    btn.innerHTML = '<i data-lucide="loader"></i> Sending OTP...';
    if (window.lucide) lucide.createIcons();

    try {
      const res = await fetch('/wallet/start-topup', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': '<%= csrfToken %>' },
        body: JSON.stringify({ amount, balanceType })
      });
      const data = await res.json();
      if (data.success) {
        topupId = data.topupId;
        document.getElementById('otpBox').style.display = 'block';
        if (data.message) {
          const note = document.getElementById('otpDeliveryNote');
          note.innerHTML = '<i data-lucide="info"></i> ' + data.message;
          if (window.lucide) lucide.createIcons();
        }
        Swal.fire({ icon: 'success', text: data.message });
      } else {
        btn.disabled = false;
        btn.innerHTML = '<i data-lucide="send"></i> Request OTP';
        if (window.lucide) lucide.createIcons();
        Swal.fire({ icon: 'error', text: data.message });
      }
    } catch (err) {
      btn.disabled = false;
      btn.innerHTML = '<i data-lucide="send"></i> Request OTP';
      if (window.lucide) lucide.createIcons();
      Swal.fire({ icon: 'error', text: 'Something went wrong. Please try again.' });
    }
  });

  document.getElementById('confirmTopup').addEventListener('click', async () => {
    const otp = document.getElementById('otp').value;
    const res = await fetch('/wallet/confirm-topup', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': '<%= csrfToken %>' },
      body: JSON.stringify({ otp, topupId })
    });
    const data = await res.json();
    if (data.success) {
      Swal.fire({ icon: 'success', text: data.message });
      setTimeout(() => location.reload(), 1500);
    } else {
      Swal.fire({ icon: 'error', text: data.message });
    }
  });

  // ── USDT preview ──────────────────────────────────────────
  let conversionController = null;

  document.getElementById('usdtAmount').addEventListener('input', async function () {
    const amount = this.value;

    if (conversionController) conversionController.abort();

    if (!amount || parseFloat(amount) <= 0) {
      document.getElementById('nairaAmount').value = '';
      return;
    }

    conversionController = new AbortController();
    try {
      const res = await fetch('/wallet/preview-conversion', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': '<%= csrfToken %>' },
        body: JSON.stringify({ amount }),
        signal: conversionController.signal
      });
      const data = await res.json();
      if (data.success) {
        document.getElementById('nairaAmount').value = '₦' + Number(data.nairaAmount).toLocaleString();
      }
    } catch (err) {
      if (err.name !== 'AbortError') console.log(err);
    }
  });

  // ── USDT convert ──────────────────────────────────────────
  document.getElementById('convertBtn').addEventListener('click', async () => {
    const amount = document.getElementById('usdtAmount').value;
    if (!amount || amount <= 0) {
      Swal.fire({ icon: 'warning', text: 'Enter valid amount' });
      return;
    }
    try {
      const res = await fetch('/wallet/convert-usdt', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': '<%= csrfToken %>' },
        body: JSON.stringify({ amount })
      });
      const data = await res.json();
      if (data.success) {
        document.getElementById('nairaAmount').value = '₦' + data.nairaAmount.toLocaleString();
        Swal.fire({ icon: 'success', text: 'Conversion successful' });
        setTimeout(() => location.reload(), 1500);
      } else {
        Swal.fire({ icon: 'error', text: data.message });
      }
    } catch (err) {
      Swal.fire({ icon: 'warning', text: 'Something went wrong' });
    }
  });

  // ── Payment method selector ───────────────────────────────
  document.getElementById('paymentMethod').addEventListener('change', function () {
    var method = this.value;
    var btn     = document.getElementById('palmpayBtn');
    var btnText = document.getElementById('palmpayBtnText');
    if (method) {
      btn.disabled    = false;
      btnText.textContent = 'Pay with ' + method;
    } else {
      btn.disabled    = true;
      btnText.textContent = 'Select a payment method';
    }
  });

  // ── Transfer RP to BitToken ───────────────────────────────
  document.getElementById('transferRpBtn').addEventListener('click', async () => {
    const amount = parseFloat(document.getElementById('rpTransferAmount').value);
    if (isNaN(amount) || amount <= 0) {
      return Swal.fire({ icon: 'warning', text: 'Enter a valid RP amount.' });
    }

    const { isConfirmed } = await Swal.fire({
      title: 'Confirm Transfer',
      html: `Transfer <strong>${amount} RP</strong> to your BitToken account?`,
      icon: 'question',
      showCancelButton: true,
      confirmButtonText: 'Yes, Transfer',
      confirmButtonColor: '#47c363',
      cancelButtonText: 'Cancel',
    });
    if (!isConfirmed) return;

    const btn = document.getElementById('transferRpBtn');
    btn.disabled = true;
    btn.innerHTML = '<i data-lucide="loader"></i> Transferring...';
    if (window.lucide) lucide.createIcons();

    try {
      const res = await fetch('/wallet/transfer-rp', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': '<%= csrfToken %>' },
        body: JSON.stringify({ rpAmount: amount }),
      });
      const data = await res.json();

      if (data.success) {
        await Swal.fire({ icon: 'success', text: data.message });
        location.reload();
      } else if (data.noMinerId) {
        btn.disabled = false;
        btn.innerHTML = '<i data-lucide="send"></i> Transfer to BitToken';
        if (window.lucide) lucide.createIcons();
        Swal.fire({
          icon: 'warning',
          title: 'Miner ID Required',
          text: data.message,
          confirmButtonText: 'Go to Profile',
          confirmButtonColor: '#47c363',
        }).then(r => { if (r.isConfirmed) window.location.href = '/user-profile'; });
      } else {
        btn.disabled = false;
        btn.innerHTML = '<i data-lucide="send"></i> Transfer to BitToken';
        if (window.lucide) lucide.createIcons();
        Swal.fire({ icon: 'error', text: data.message });
      }
    } catch (err) {
      btn.disabled = false;
      btn.innerHTML = '<i data-lucide="send"></i> Transfer to BitToken';
      if (window.lucide) lucide.createIcons();
      Swal.fire({ icon: 'error', text: 'Something went wrong. Please try again.' });
    }
  });

  // ── Fund Naira Wallet ─────────────────────────────────────
  document.getElementById('palmpayBtn').addEventListener('click', async () => {
    const method = document.getElementById('paymentMethod').value;
    const amount = document.getElementById('palmpayAmount').value;
    if (!method) {
      Swal.fire({ icon: 'warning', text: 'Please select a payment method' });
      return;
    }
    if (!amount || amount < 100) {
      Swal.fire({ icon: 'warning', text: 'Enter a valid amount (minimum ₦100)' });
      return;
    }
    try {
      const response = await fetch('/palmpay/create', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': '<%= csrfToken %>' },
        body: JSON.stringify({ amount, paymentMethod: method })
      });
      const data = await response.json();
      if (data.success) {
        window.location.href = data.paymentUrl;
      } else {
        Swal.fire({ icon: 'warning', text: data.message || 'Payment failed' });
      }
    } catch (error) {
      Swal.fire({ icon: 'warning', text: 'Something went wrong' });
    }
  });
</script>