    <script>
const modal = document.getElementById('paymentModal');
let selectedProductId = null;

// Open modal
document.getElementById('buyNowBtn').addEventListener('click', function(e){
    e.preventDefault();
    
    selectedProductId = this.dataset.id; // ✅ store productId
    modal.style.display = 'block';
});

// Cancel
document.getElementById('cancelPaymentBtn').addEventListener('click', () => {
    modal.style.display = 'none';
});

// PalmPay
// ======================================================
// FRONTEND JS
// ======================================================









  // ================= EDIT MODAL =================

    const editModal = document.getElementById('editModal');
    const openEditModal = document.getElementById('openEditModal');
    const closeModal = document.querySelector('.close-modal');

    openEditModal.addEventListener('click', () => {
        editModal.style.display = 'block';
    });

    closeModal.addEventListener('click', () => {
        editModal.style.display = 'none';
    });



    // ================= DELETE MODAL =================

    const deleteModal = document.getElementById('deleteModal');
    const deleteBtn = document.getElementById('deleteBtn');
    const closeDeleteModal = document.querySelector('.close-delete-modal');
    const cancelDelete = document.getElementById('cancelDelete');
    const confirmDelete = document.getElementById('confirmDelete');

    deleteBtn.addEventListener('click', () => {
        deleteModal.style.display = 'block';
    });

    closeDeleteModal.addEventListener('click', () => {
        deleteModal.style.display = 'none';
    });

    cancelDelete.addEventListener('click', () => {
        deleteModal.style.display = 'none';
    });

    confirmDelete.addEventListener('click', () => {

        window.location.href =
            "/delete-checkout/<%= checkout._id %>";

    });



    // CLOSE MODAL WHEN CLICKING OUTSIDE

    window.onclick = function(event){

        if(event.target == editModal){
            editModal.style.display = "none";
        }

        if(event.target == deleteModal){
            deleteModal.style.display = "none";
        }

    }

    // Wallet
// ✅ Wallet payment (NEW LOGIC)
document.getElementById('walletBtn').addEventListener('click', async () => {
    try {
        const res = await fetch('/wallet/pay', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ productId: selectedProductId }) // ✅ send productId
        });

        const data = await res.json();

        if (data.success) {
           // alert('✅ Payment successful');
               Swal.fire({
            icon: 'success',
            text: 'Payment successful'
        });
            
            modal.style.display = 'none';
            location.reload();
        } else {
            //alert(data.message);
             Swal.fire({
            icon: 'error',
            text: `${data.message}`
        });
        }

    } catch (error) {
        console.log(error);
        //alert('Payment error');
           Swal.fire({
            icon: 'error',
            text: `Payment error`
        });
    }
});
</script>
   
