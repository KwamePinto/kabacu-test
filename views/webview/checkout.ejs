<script>
  const successMsg = <%- JSON.stringify(success_msg) %>;
  const errorMsg   = <%- JSON.stringify(error_msg) %>;
  if (successMsg.length > 0) Swal.fire({ icon: 'success', text: successMsg[0] });
  if (errorMsg.length   > 0) Swal.fire({ icon: 'error',   text: errorMsg[0] });
</script>

<section class="checkout-page">
  <div class="container">

    <div class="page-hero">
      <h1 class="page-hero__title">
        <i data-lucide="shopping-bag"></i>
        Checkout
      </h1>
    </div>

    <div class="checkout-card">
      <div class="checkout-card__header">
        <h2 class="checkout-card__title">Your Order</h2>
      </div>

      <!-- Item row -->
      <div class="checkout-item">
        <div class="checkout-item__img">
          <img src="<%= checkout.product.images[0] %>" alt="<%= checkout.product.dataDetails.plan_type %>">
        </div>
        <div class="checkout-item__details">
          <div class="checkout-item__network"><%= checkout.product.dataDetails.network %></div>
          <div class="checkout-item__name">
            <%= checkout.product.dataDetails.plan_type %> · <%= checkout.product.dataDetails.plan_name %>
          </div>
          <div class="checkout-item__phone">
            <i data-lucide="phone"></i>
            <%= checkout.phone %>
          </div>
          <div class="checkout-item__actions">
            <button class="checkout-action-btn" id="openEditModal">
              <i data-lucide="edit-2"></i>
              Edit
            </button>
            <button class="checkout-action-btn checkout-action-btn--danger" id="deleteBtn">
              <i data-lucide="trash-2"></i>
              Remove
            </button>
          </div>
        </div>
        <div class="checkout-item__price">₦<%= checkout.product.dataDetails.amount %></div>
      </div>

      <!-- Footer -->
      <div class="checkout-card__footer">
        <a href="/" class="btn btn--ghost btn--sm">
          <i data-lucide="arrow-left"></i>
          Back to Shop
        </a>
        <button id="buyNowBtn" data-id="<%= checkout.product._id %>" class="btn btn--primary">
          <i data-lucide="credit-card"></i>
          Pay Now
        </button>
      </div>
    </div>

  </div>
</section>

<!-- Payment method modal -->
<div id="paymentModal" class="modal-overlay" role="dialog">
  <div class="modal-box">
    <div class="modal-box__header">
      <h3 class="modal-title">Select Payment Method</h3>
      <button class="modal-close" id="cancelPaymentBtn">
        <i data-lucide="x"></i>
      </button>
    </div>
    <div class="payment-modal-methods">
      <div class="payment-method-opt" id="walletBtn">
        <div class="payment-method-opt__icon"><i data-lucide="wallet"></i></div>
        <div style="flex:1;">
          <div class="payment-method-opt__label">Pay with My Wallet</div>
          <div class="payment-method-opt__sub">Balance: <strong>₦<%= (walletBalance || 0).toLocaleString('en-NG', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %></strong></div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Edit modal -->
<div id="editModal" class="modal-overlay" role="dialog">
  <div class="modal-box">
    <div class="modal-box__header">
      <h3 class="modal-title">Edit Order Details</h3>
      <button class="modal-close" id="closeEditModal">
        <i data-lucide="x"></i>
      </button>
    </div>
    <form action="/update-checkout/<%= checkout._id %>" method="POST">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <div class="form-group">
        <label class="form-label">Phone Number</label>
        <div class="phone-field">
          <select class="phone-field__code" id="editCountryCode">
            <option value="+234">🇳🇬 +234</option>
          </select>
          <input type="tel" id="editPhoneInput" name="phone" class="phone-field__num"
                 placeholder="XXX XXX XXXX" maxlength="10" inputmode="numeric"
                 autocomplete="tel-national">
        </div>
        <small id="editPhoneError" style="color:var(--error);display:none;margin-top:6px;">
          Enter a valid 10-digit Nigerian number (e.g. 801 234 5678)
        </small>
      </div>
      <div class="form-group">
        <label class="form-label">Network</label>
        <div class="input-wrapper">
          <i data-lucide="wifi"></i>
          <input type="text" name="network" value="<%= checkout.product.dataDetails.network %>" class="form-input">
        </div>
      </div>
      <div class="modal-actions">
        <button type="submit" class="btn btn--primary btn--full">
          <i data-lucide="save"></i>
          Save Changes
        </button>
      </div>
    </form>
  </div>
</div>

<!-- Delete confirm modal -->
<div id="deleteModal" class="modal-overlay" role="dialog">
  <div class="modal-box">
    <div class="modal-box__header">
      <h3 class="modal-title">Remove Item</h3>
      <button class="modal-close" id="closeDeleteModal">
        <i data-lucide="x"></i>
      </button>
    </div>
    <p style="margin-bottom:20px;color:var(--color-muted);">Are you sure you want to remove this item from your checkout?</p>
    <div class="modal-actions">
      <button id="confirmDelete" class="btn btn--danger btn--full">
        <i data-lucide="trash-2"></i>
        Yes, Remove
      </button>
      <button id="cancelDelete" class="btn btn--ghost btn--full">Cancel</button>
    </div>
  </div>
</div>

<script>
const paymentModal = document.getElementById('paymentModal');
const editModal    = document.getElementById('editModal');
const deleteModal  = document.getElementById('deleteModal');
let selectedProductId = null;

// ── Payment modal ──
document.getElementById('buyNowBtn').addEventListener('click', function(e) {
  e.preventDefault();
  selectedProductId = this.dataset.id;
  paymentModal.classList.add('open');
});
document.getElementById('cancelPaymentBtn').addEventListener('click', () => paymentModal.classList.remove('open'));
paymentModal.addEventListener('click', e => { if (e.target === paymentModal) paymentModal.classList.remove('open'); });

// ── Edit modal ──
document.getElementById('openEditModal').addEventListener('click', () => editModal.classList.add('open'));
document.getElementById('closeEditModal').addEventListener('click', () => editModal.classList.remove('open'));
editModal.addEventListener('click', e => { if (e.target === editModal) editModal.classList.remove('open'); });

// ── Delete modal ──
document.getElementById('deleteBtn').addEventListener('click', () => deleteModal.classList.add('open'));
document.getElementById('closeDeleteModal').addEventListener('click', () => deleteModal.classList.remove('open'));
document.getElementById('cancelDelete').addEventListener('click', () => deleteModal.classList.remove('open'));
deleteModal.addEventListener('click', e => { if (e.target === deleteModal) deleteModal.classList.remove('open'); });

document.getElementById('confirmDelete').addEventListener('click', () => {
  window.location.href = '/delete-checkout/<%= checkout._id %>';
});

// ── Edit modal: phone field ──
(function() {
  var editPhone  = document.getElementById('editPhoneInput');
  var editCode   = document.getElementById('editCountryCode');
  var editErr    = document.getElementById('editPhoneError');
  var editForm   = document.querySelector('#editModal form');

  if (!editPhone || !editForm) return;

  /* Pre-fill: strip +234 prefix if already stored in international format */
  var stored = '<%= checkout.phone %>';
  if (stored.startsWith('+234')) {
    editPhone.value = stored.slice(4);
  } else if (stored.startsWith('0') && stored.length === 11) {
    editPhone.value = stored.slice(1);   /* local 0XXXXXXXXXX → drop leading 0 */
  } else {
    editPhone.value = stored;
  }

  editPhone.addEventListener('input', function() {
    this.value = this.value.replace(/\D/g, '').slice(0, 10);
  });

  editForm.addEventListener('submit', function(e) {
    var num = editPhone.value.trim();
    if (!/^[789]\d{9}$/.test(num)) {
      e.preventDefault();
      editErr.style.display = 'block';
      return;
    }
    editErr.style.display = 'none';
    /* Write combined international value into the named input before submit */
    editPhone.value = editCode.value + num;
  });
})();

// ── Wallet payment ──
document.getElementById('walletBtn').addEventListener('click', async () => {
  const walletBtn = document.getElementById('walletBtn');
  walletBtn.style.opacity = '0.6';
  walletBtn.style.pointerEvents = 'none';
  Swal.fire({
    title: 'Processing Payment',
    text: 'Please wait while we process your order...',
    allowOutsideClick: false,
    allowEscapeKey: false,
    didOpen: () => Swal.showLoading()
  });
  try {
    const res  = await fetch('/wallet/pay', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': '<%= csrfToken %>' },
      body: JSON.stringify({ productId: selectedProductId })
    });
    const data = await res.json();
    Swal.close();
    if (data.success) {
      Swal.fire({ icon: 'success', title: 'Successful', text: 'Package Purchased Successfully' });
      paymentModal.classList.remove('open');
      setTimeout(() => window.location.href = '/', 1500);
    } else {
      walletBtn.style.opacity = '1';
      walletBtn.style.pointerEvents = '';
      Swal.fire({ icon: 'error', title: 'Payment Failed', text: data.message });
    }
  } catch (error) {
    Swal.close();
    walletBtn.style.opacity = '1';
    walletBtn.style.pointerEvents = '';
    Swal.fire({ icon: 'error', title: 'Error', text: 'Something went wrong' });
  }
});
</script>
