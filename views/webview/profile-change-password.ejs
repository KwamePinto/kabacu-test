<script>
  const successMsg = <%- JSON.stringify(success_msg) %>;
  const errorMsg   = <%- JSON.stringify(error_msg) %>;
  if (successMsg && successMsg.length > 0) Swal.fire({ icon: 'success', text: successMsg[0] });
  if (errorMsg && errorMsg.length > 0) Swal.fire({ icon: 'error', text: errorMsg[0] });
</script>

<section class="auth-page">
  <div class="auth-card">
    <div class="auth-card__logo">
      <img src="/assets/images/new.PNG" alt="Data Mall">
    </div>

    <h1 class="auth-card__title">Change password</h1>
    <p class="auth-card__sub">
      We'll send a one-time code to <strong><%= email %></strong> to confirm it's you.
    </p>

    <form action="/user/profile-change-password" method="post" class="auth-form">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">

      <div style="background:#e8f5ee;border:1px solid #b7dfca;border-radius:10px;padding:16px 20px;margin-bottom:24px;display:flex;align-items:center;gap:12px;">
        <i data-lucide="mail" style="color:#15a844;flex-shrink:0;width:20px;height:20px;"></i>
        <div>
          <p style="margin:0;font-size:13px;color:#555;">Code will be sent to</p>
          <p style="margin:0;font-size:15px;font-weight:600;color:#1a1a2e;"><%= email %></p>
        </div>
      </div>

      <button type="submit" class="btn btn--primary btn--full btn--lg">
        <i data-lucide="send" style="width:16px;height:16px;margin-right:6px;"></i>
        Send Verification Code
      </button>
    </form>

    <div class="auth-divider"><span>Changed your mind?</span></div>
    <a href="/user-profile" class="btn btn--outline btn--full">Back to Profile</a>
  </div>
</section>