<section class="history-page">
  <div class="container">

     <div style="margin-top:24px;">
      <a href="/user-profile" class="btn btn--outline">
        <i data-lucide="arrow-left"></i>
        Back to Profile
      </a>
    </div>

    <div class="page-hero">
      <h1 class="page-hero__title">
        <i data-lucide="clock"></i>
        Order History
      </h1>
      <p class="page-hero__sub">All your transactions in one place</p>
    </div>

    <h2 style="font-size:16px;font-weight:700;color:var(--color-text);margin:32px 0 12px;">Purchases &amp; Orders</h2>
    <div class="tx-table-wrap">
      <table class="tx-table">
  <thead>
    <tr>
      <th>Qty</th>
      <th>Package</th>
      <th>Amount</th>
      <th>Status</th>
      <th>Date</th>
      <th>Action</th>
    </tr>
  </thead>

  <tbody>
    <% if (transactions && transactions.length > 0) { %>
      <% transactions.forEach(function(tx) { %>
        <%
          let product =
            tx.product ||
            tx.products?.[0]?.product;
        %>

        <tr>
          <td data-label="Qty">
            <%= tx.products?.[0]?.quantity || 1 %>
          </td>

          <td data-label="Package">
            <% if (product && product.category === 'DATA') { %>
              <strong>
                <%= product.dataDetails.network %> —
                <%= product.dataDetails.plan_type %>
                (<%= product.dataDetails.plan_name %>)
              </strong>
              <br />
              <small style="color:var(--color-muted);">
                Phone: <%= tx.phone %>
              </small>

            <% } else if (product && product.category === 'COURSES') { %>
              <%= product.coursesDetails.course_title %>

            <% } else { %>
              <span style="color:var(--color-muted);">—</span>
            <% } %>
          </td>

          <td data-label="Amount">
            ₦<%= tx.amount %>
          </td>

          <td data-label="Status">
            <% if (tx.status === 'success') { %>
              <span class="badge badge--success">
                <i data-lucide="check-circle"></i>
                Success
              </span>

            <% } else if (tx.status === 'failed') { %>
              <span class="badge badge--error">
                <i data-lucide="x-circle"></i>
                Failed
              </span>

            <% } else { %>
              <span class="badge badge--warning">
                <i data-lucide="clock"></i>
                <%= tx.status %>
              </span>
            <% } %>
          </td>

          <td data-label="Date">
            <small>
              <%= new Date(tx.createdAt).toLocaleDateString('en-GB', { day:'2-digit', month:'short', year:'numeric' }) %>
              <br>
              <%= new Date(tx.createdAt).toLocaleTimeString('en-GB', { hour:'2-digit', minute:'2-digit' }) %>
            </small>
          </td>

          <td data-label="Action">
            <% if (tx.status === 'failed') { %>
              <button
                class="btn btn--outline btn--sm retry-btn"
                data-id="<%= tx._id %>">
                <i data-lucide="refresh-cw"></i>
                Retry
              </button>
            <% } else { %>
              <span style="color:var(--color-muted);">—</span>
            <% } %>
          </td>
        </tr>
      <% }) %>

    <% } else { %>
      <tr>
        <td colspan="6">
          <div class="empty-state">
            <i data-lucide="inbox"></i>
            <p>No transactions found</p>
            <a href="/category/data-category" class="btn btn--primary btn--sm">
              Shop Now
            </a>
          </div>
        </td>
      </tr>
    <% } %>
  </tbody>
</table>
    </div>

    <!-- Course Enrolments -->
    <h2 style="font-size:16px;font-weight:700;color:var(--color-text);margin:40px 0 12px;">
      <i data-lucide="book-open" style="width:16px;height:16px;vertical-align:-2px;margin-right:6px;"></i>
      Course Enrolments
    </h2>
    <div class="tx-table-wrap">
      <table class="tx-table">
        <thead>
          <tr>
            <th>Course</th>
            <th>Amount</th>
            <th>Type</th>
            <th>Date</th>
          </tr>
        </thead>
        <tbody>
          <% if (coursePurchases && coursePurchases.length > 0) { %>
            <% coursePurchases.forEach(function(cp) { %>
              <tr>
                <td data-label="Course">
                  <strong><%= cp.courseTitle || 'Course' %></strong>
                </td>
                <td data-label="Amount">
                  <% if (cp.free) { %>
                    <span style="color:var(--color-primary);font-weight:600;">Free</span>
                  <% } else { %>
                    ₦<%= Number(cp.price || 0).toLocaleString() %>
                  <% } %>
                </td>
                <td data-label="Type">
                  <% if (cp.free) { %>
                    <span class="badge badge--success">Free Enrolment</span>
                  <% } else { %>
                    <span class="badge badge--success">Paid</span>
                  <% } %>
                </td>
                <td data-label="Date">
                  <small>
                    <%= new Date(cp.createdAt).toLocaleDateString('en-GB', { day:'2-digit', month:'short', year:'numeric' }) %>
                    <br>
                    <%= new Date(cp.createdAt).toLocaleTimeString('en-GB', { hour:'2-digit', minute:'2-digit' }) %>
                  </small>
                </td>
              </tr>
            <% }) %>
          <% } else { %>
            <tr>
              <td colspan="4">
                <div class="empty-state">
                  <i data-lucide="book-open"></i>
                  <p>No course enrolments yet</p>
                  <a href="/category/course-category" class="btn btn--primary btn--sm">Browse Courses</a>
                </div>
              </td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>

  </div>
</section>

<script>
document.addEventListener('click', async function (e) {
  const btn = e.target.closest('.retry-btn');
  if (!btn) return;

  const txId = btn.dataset.id;

  const confirm = await Swal.fire({
    title: 'Retry Purchase?',
    text: 'This will attempt to buy the data again',
    icon: 'warning',
    showCancelButton: true,
    confirmButtonText: 'Yes, Retry'
  });

  if (!confirm.isConfirmed) return;

  btn.disabled = true;
  btn.innerHTML = 'Processing...';

  try {
    const res = await fetch('/retry-transaction', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': '<%= csrfToken %>' },
      body: JSON.stringify({ transactionId: txId })
    });

    const data = await res.json();

    if (data.success) {
      Swal.fire('Success', 'Transaction completed!', 'success')
        .then(() => location.reload());
    } else if (data.insufficientBalance) {
      window.location.href = '/my-wallet';
    } else {
      Swal.fire('Error', data.message, 'error');
      btn.disabled = false;
      btn.innerHTML = '<i data-lucide="refresh-cw"></i> Retry';
    }

  } catch (err) {
    Swal.fire('Error', 'Something went wrong', 'error');
    btn.disabled = false;
    btn.innerHTML = '<i data-lucide="refresh-cw"></i> Retry';
  }
});
</script>