<script>
  const successMsg = <%- JSON.stringify(success_msg) %>;
  const errorMsg   = <%- JSON.stringify(error_msg) %>;
  if (successMsg && successMsg.length > 0) Swal.fire({ icon: 'success', text: successMsg[0] });
  if (errorMsg && errorMsg.length > 0) Swal.fire({ icon: 'error', text: errorMsg[0] });
</script>

<section class="auth-page">
  <div class="auth-card">
    <div class="auth-card__logo">
      <img src="/assets/images/new.PNG" alt="Data Mall">
    </div>

    <h1 class="auth-card__title">Verify OTP</h1>
    <p class="auth-card__sub">An OTP has been sent to <strong><%= email %></strong></p>

    <form action="/user/verify-otp" method="post" class="auth-form">
      <div class="form-group">
        <label class="form-label" style="text-align: center; display: block; margin-bottom: 15px;">OTP Verification Code</label>
        <div class="input-wrapper" style="justify-content: center;">
          <input type="text" name="otp" class="form-input" placeholder="------" required pattern="[0-9]{6}" maxlength="6" inputmode="numeric" style="text-align: center; letter-spacing: 12px; font-size: 1.5rem; font-weight: bold; width: 100%; max-width: 280px; padding: 12px;">
        </div>
      </div>

      <button type="submit" class="btn btn--primary btn--full btn--lg" style="margin-top: 15px;">Verify Code</button>
    </form>

    <div style="text-align:center; margin-top:20px;">
      <form action="/user/resend-otp" method="post" id="resendForm" style="display:inline;">
        <button type="submit" id="resendBtn" class="btn btn--link" style="color:var(--primary); font-size:14px; background:none; border:none; cursor:pointer; padding:0; text-decoration:underline; font-weight: 500;">
          Resend Code
        </button>
      </form>
    </div>

    <div class="auth-divider"><span>Back to signup?</span></div>
    <a href="/user/signup" class="btn btn--outline btn--full">Register Again</a>
  </div>
</section>
