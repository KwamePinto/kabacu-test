      <script>
        <!-- ✅ Your SweetAlert Logic -->

    const successMsg = <%- JSON.stringify(success_msg) %>;
    const errorMsg = <%- JSON.stringify(error_msg) %>;

    if (successMsg.length > 0) {
        Swal.fire({
            icon: 'success',
            title: 'Success',
            text: successMsg[0]
        });
    }

    if (errorMsg.length > 0) {
        Swal.fire({
            icon: 'error',
            title: 'Error',
            text: errorMsg[0]
        });
    }


    </script>
