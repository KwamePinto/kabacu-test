<script>
  const successMsg = <%- JSON.stringify(success_msg) %>;
  const errorMsg   = <%- JSON.stringify(error_msg) %>;
  if (successMsg.length > 0) Swal.fire({ icon: 'success', text: successMsg[0] });
  if (errorMsg.length   > 0) Swal.fire({ icon: 'error',   text: errorMsg[0] });
</script>

<section class="auth-page">
  <div class="auth-card">

    <div class="auth-card__logo">
      <img src="/assets/images/new.PNG" alt="Data Mall">
    </div>

    <h1 class="auth-card__title">Welcome back</h1>
    <p class="auth-card__sub">Sign in to your account</p>

    <form action="/user/login" method="post" class="auth-form">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <div class="form-group">
        <label class="form-label">Email address</label>
        <div class="input-wrapper">
          <i data-lucide="mail"></i>
          <input type="email" name="email" class="form-input" placeholder="you@example.com" required>
        </div>
      </div>

      <div class="form-group">
        <label class="form-label">Password</label>
        <div class="input-wrapper input-wrapper--pw">
          <i data-lucide="lock"></i>
          <input type="password" name="password" id="loginPassword" class="form-input" placeholder="Enter your password" required minlength="6">
          <button type="button" class="pw-toggle" data-target="loginPassword" aria-label="Toggle password visibility">
            <i data-lucide="eye" class="pw-toggle__show"></i>
            <i data-lucide="eye-off" class="pw-toggle__hide" style="display:none;"></i>
          </button>
        </div>
      </div>

      <div class="form-group">
        <div style="display:flex;align-items:center;gap:8px;margin-bottom:6px;">
          <label class="form-label" style="margin-bottom:0;">Human check</label>
          <span id="mathQuestion" style="background:#e8f5ee;color:#15a844;border:1.5px dashed #15a844;border-radius:8px;padding:4px 14px;font-size:1.1rem;font-weight:700;letter-spacing:2px;"><%= mathQuestion %> = ?</span>
          <button type="button" id="refreshCaptcha" title="Get new question" style="background:none;border:none;cursor:pointer;color:#15a844;padding:4px;display:flex;align-items:center;flex-shrink:0;">
            <i data-lucide="refresh-cw" style="width:16px;height:16px;pointer-events:none;"></i>
          </button>
        </div>
        <div class="input-wrapper">
          <i data-lucide="calculator"></i>
          <input type="number" id="mathAnswer" name="mathAnswer" class="form-input" placeholder="Enter the answer" required inputmode="numeric" autocomplete="off">
        </div>
      </div>

      <button type="submit" class="btn btn--primary btn--full btn--lg">Sign In</button>
    </form>

    <div style="text-align:center; margin-top:12px;">
      <a href="/user/forgot-password" style="font-size:13px; color:var(--primary); text-decoration:none;">Forgot password?</a>
    </div>

    <div class="auth-divider"><span>Don't have an account?</span></div>

    <a href="/user/signup" class="btn btn--outline btn--full">Create account</a>
  </div>
</section>

<script>
(function() {
  document.querySelectorAll('.pw-toggle').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var input = document.getElementById(btn.getAttribute('data-target'));
      if (!input) return;
      var show = input.type === 'password';
      input.type = show ? 'text' : 'password';
      btn.querySelector('.pw-toggle__show').style.display = show ? 'none' : '';
      btn.querySelector('.pw-toggle__hide').style.display = show ? ''     : 'none';
    });
  });
})();

/* ── Math captcha: parse equation and return expected answer ── */
function getMathAnswer() {
  var text = document.getElementById('mathQuestion').textContent.replace('= ?', '').trim();
  var m = text.match(/(\d+)\s*([+\-−×÷*\/])\s*(\d+)/);
  if (!m) return NaN;
  var a = parseInt(m[1], 10), op = m[2], b = parseInt(m[3], 10);
  if (op === '+')                      return a + b;
  if (op === '-' || op === '−')   return a - b;
  if (op === '*' || op === '×')        return a * b;
  if (op === '/' || op === '÷')        return a / b;
  return NaN;
}

/* ── Real-time border feedback on math answer ────────────── */
document.getElementById('mathAnswer').addEventListener('input', function() {
  if (this.value === '') { this.style.outline = ''; this.style.borderColor = ''; return; }
  var correct = parseInt(this.value, 10) === getMathAnswer();
  this.style.outline     = '2px solid ' + (correct ? '#15a844' : '#dc3545');
  this.style.borderColor =                (correct ? '#15a844' : '#dc3545');
});

/* ── Refresh math captcha ─────────────────────────────── */
document.getElementById('refreshCaptcha').addEventListener('click', async function() {
  var btn = this;
  btn.style.opacity = '0.4';
  btn.style.pointerEvents = 'none';
  try {
    var res  = await fetch('/user/refresh-captcha?type=login');
    var data = await res.json();
    document.getElementById('mathQuestion').textContent = data.question + ' = ?';
    var inp = document.getElementById('mathAnswer');
    inp.value = '';
    inp.style.outline = '';
    inp.style.borderColor = '';
  } catch (e) { /* silently ignore */ }
  btn.style.opacity = '';
  btn.style.pointerEvents = '';
});
</script>
