<script>
  const successMsg = <%- JSON.stringify(success_msg) %>;
  const errorMsg   = <%- JSON.stringify(error_msg) %>;
  if (successMsg && successMsg.length > 0) Swal.fire({ icon: 'success', text: successMsg[0] });
  if (errorMsg && errorMsg.length > 0) Swal.fire({ icon: 'error', text: errorMsg[0] });
</script>

<section class="auth-page">
  <div class="auth-card">
    <div class="auth-card__logo">
      <img src="/assets/images/new.PNG" alt="Data Mall">
    </div>

    <h1 class="auth-card__title">Forgot password?</h1>
    <p class="auth-card__sub">Enter your email and we'll send you a reset code</p>

    <form action="/user/forgot-password" method="post" class="auth-form">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <div class="form-group">
        <label class="form-label">Email address</label>
        <div class="input-wrapper">
          <i data-lucide="mail"></i>
          <input type="email" name="email" class="form-input" placeholder="you@example.com" required>
        </div>
      </div>

      <button type="submit" class="btn btn--primary btn--full btn--lg">Send Reset Code</button>
    </form>

    <div class="auth-divider"><span>Remembered your password?</span></div>
    <a href="/user/login" class="btn btn--outline btn--full">Back to Sign In</a>
  </div>
</section>