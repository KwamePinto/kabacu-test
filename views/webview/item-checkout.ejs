<section class="checkout-page">
  <div class="container">

    <div class="page-hero">
      <h1 class="page-hero__title">
        <i data-lucide="shopping-cart"></i>
        Cart
      </h1>
    </div>

    <div class="cart-layout">
      <!-- Cart table -->
      <div>
        <div class="cart-table-wrap">
          <table class="cart-table">
            <thead>
              <tr>
                <th>Product</th>
                <th>Price</th>
                <th>Qty</th>
                <th>Total</th>
              </tr>
            </thead>
            <tbody>
              <% if (cart.length > 0) { %>
                <% cart.forEach(item => { %>
                <tr>
                  <td>
                    <div class="cart-product-thumb">
                      <img src="<%= item.product.images[0] %>" alt="<%= item.name %>">
                      <span><%= item.name %></span>
                    </div>
                  </td>
                  <td>₦<%= item.price.toLocaleString() %></td>
                  <td><%= item.quantity %></td>
                  <td>₦<%= item.subtotal.toLocaleString() %></td>
                </tr>
                <% }) %>
              <% } else { %>
              <tr>
                <td colspan="4">
                  <div class="empty-state">
                    <i data-lucide="shopping-cart"></i>
                    <p>Your cart is empty</p>
                    <a href="/" class="btn btn--primary btn--sm">Shop Now</a>
                  </div>
                </td>
              </tr>
              <% } %>
            </tbody>
          </table>
        </div>
        <div style="margin-top:16px;">
          <a href="/" class="btn btn--ghost btn--sm">
            <i data-lucide="arrow-left"></i>
            Back to Shop
          </a>
        </div>
      </div>

      <!-- Order summary -->
      <div class="order-summary">
        <h3 class="order-summary__title">Order Summary</h3>
        <div class="order-summary__row">
          <span>Subtotal (<%= totalItems %> items)</span>
          <span>₦<%= total.toLocaleString() %></span>
        </div>
        <div class="order-summary__row">
          <span>Delivery fee</span>
          <span>₦0.00</span>
        </div>
        <div class="order-summary__row">
          <span>Total</span>
          <span>₦<%= total.toLocaleString() %></span>
        </div>
        <div class="order-summary__cta">
          <button id="buyNowBtn" class="btn btn--primary btn--full btn--lg">
            <i data-lucide="credit-card"></i>
            Checkout
          </button>
        </div>
      </div>
    </div>
</div>
    <br>

    

    <!-- FOOTER -->
    <%- include('../partials/footer.ejs')%>
    <!--Footer For Mobile-->
    <div class="mobile-footer">
        <div class="mobile-footer-inner">
            <div class="mobile-block block-menu-main">
                <a class="menu-bar menu-toggle btn-toggle" data-object="open-mobile-menu" href="javascript:void(0)">
                    <span class="fa fa-bars"></span>
                    <span class="text">Menu</span>
                </a>
            </div>
            <div class="mobile-block block-sidebar">
                <a class="menu-bar filter-toggle btn-toggle" data-object="open-mobile-filter" href="javascript:void(0)">
                    <i class="fa fa-sliders" aria-hidden="true"></i>
                    <span class="text">Sidebar</span>
                </a>
            </div>
            <div class="mobile-block block-minicart">
                <a class="link-to-cart" href="#">
                    <span class="fa fa-shopping-bag" aria-hidden="true"></span>
                    <span class="text">Cart</span>
                </a>
            </div>
            <div class="mobile-block block-global">
                <a class="menu-bar myaccount-toggle btn-toggle" data-object="global-panel-opened" href="javascript:void(0)">
                    <span class="fa fa-globe"></span>
                    <span class="text">Global</span>
                </a>
            </div>
        </div>
    </div>
    <div class="payment-modal-methods">
      <div class="payment-method-opt" id="walletBtn">
        <div class="payment-method-opt__icon"><i data-lucide="wallet"></i></div>
        <div>
          <div class="payment-method-opt__label">Pay with Wallet</div>
          <div class="payment-method-opt__sub">Use your USDT or Naira balance</div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
const modal = document.getElementById('paymentModal');

document.getElementById('buyNowBtn').addEventListener('click', function(e) {
  e.preventDefault();
  modal.classList.add('open');
});

// Cancel
document.getElementById('cancelPaymentBtn').addEventListener('click', () => {
    modal.style.display = 'none';
});

// Paystack
document.getElementById('paystackBtn').addEventListener('click', () => {
    window.location.href = '/payment/paystack';
});

// Wallet
// document.getElementById('walletBtn').addEventListener('click', () => {
//     window.location.href = '/wallet/checkout';
// });



// document.getElementById('walletBtn').addEventListener('click', async () => {

 

// });

const walletBtn = document.getElementById('walletBtn');

walletBtn.addEventListener('click', async () => {
  const confirmPay = await Swal.fire({
    title: 'Pay with wallet?',
    icon: 'question',
    showCancelButton: true,
    confirmButtonText: 'Yes, Pay'
  });
  if (!confirmPay.isConfirmed) return;
  try {
    walletBtn.style.opacity = '0.6';
    walletBtn.style.pointerEvents = 'none';
    const res  = await fetch('/wallet/pay', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': '<%= csrfToken %>' }
    });
    const data = await res.json();
    if (data.success) {
      Swal.fire({ icon: 'success', text: 'Payment successful' });
      modal.classList.remove('open');
      setTimeout(() => window.location.href = '/', 1500);
    } else {
      Swal.fire({ icon: 'error', text: data.message });
      walletBtn.style.opacity = '1';
      walletBtn.style.pointerEvents = '';
    }
  } catch (err) {
    Swal.fire({ icon: 'error', text: 'Something went wrong' });
    walletBtn.style.opacity = '1';
    walletBtn.style.pointerEvents = '';
  }
});
</script>

 

