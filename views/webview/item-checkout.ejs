    <script id="payment-script">

const modal = document.getElementById('paymentModal');

// Open modal
document.getElementById('buyNowBtn').addEventListener('click', function(e){
    e.preventDefault();
    modal.style.display = 'block';
});

// Cancel
document.getElementById('cancelPaymentBtn').addEventListener('click', () => {
    modal.style.display = 'none';
});

// Paystack
document.getElementById('paystackBtn').addEventListener('click', () => {
    window.location.href = '/payment/paystack';
});


const walletBtn = document.getElementById('walletBtn');

walletBtn.addEventListener('click', async () => {

  const confirmPay = confirm('Pay with wallet?');
  if (!confirmPay) return;

  try {
    walletBtn.disabled = true;
    walletBtn.innerText = 'Processing...';

    const res = await fetch('/wallet/pay', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json'
      }
    });

    const data = await res.json();

    if (data.success) {
      alert('✅ Payment successful');

      // close modal
      document.getElementById('paymentModal').style.display = 'none';

      // refresh page OR redirect
      window.location.href = '/'; // or success page

    } else {
      alert('❌ ' + data.message);
    }

  } catch (err) {
    console.error(err);
    alert('Something went wrong');
  } finally {
    walletBtn.disabled = false;
    walletBtn.innerText = 'Pay with Wallet';
  }

});
</script>


