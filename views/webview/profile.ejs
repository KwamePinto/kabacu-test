<script>
  const successMsg = <%- JSON.stringify(success_msg) %>;
  const errorMsg   = <%- JSON.stringify(error_msg) %>;
  if (successMsg.length > 0) Swal.fire({ icon: 'success', text: successMsg[0] });
  if (errorMsg.length   > 0) Swal.fire({ icon: 'error',   text: errorMsg[0] });
</script>

<div class="container">
<div class="acct-page">

  <!-- ── Avatar + identity ────────────────────────────────── -->
  <div class="acct-hero">
    <div class="acct-avatar">
      <%= user.username ? user.username[0].toUpperCase() : 'U' %>
    </div>
    <h2 class="acct-name"><%= user.username %></h2>
    <p class="acct-email"><%= user.email %></p>
  </div>

  <!-- ── Balances ─────────────────────────────────────────── -->
  <div class="acct-balances">
    <div class="acct-balance-card">
      <i data-lucide="wallet"></i>
      <div class="acct-balance-card__val">₦<%= ((wallet && wallet.balances && wallet.balances.NAIRA) || 0).toLocaleString() %></div>
      <div class="acct-balance-card__lbl">Wallet Balance</div>
    </div>
    <div class="acct-balance-card">
      <i data-lucide="star"></i>
      <div class="acct-balance-card__val"><%= user.rpBalance || 0 %></div>
      <div class="acct-balance-card__lbl">Reward Points</div>
    </div>
  </div>

  <!-- ── Quick links ──────────────────────────────────────── -->
  <div class="acct-section">
    <h3 class="acct-section__title">Account Activity</h3>
    <div class="acct-links">

      <a href="/history" class="acct-link">
        <div class="acct-link__icon">
          <i data-lucide="package"></i>
        </div>
        <div class="acct-link__body">
          <span class="acct-link__label">Order History</span>
          <% if (recentOrders && recentOrders.length > 0) { %>
          <span class="acct-link__sub"><%= recentOrders.length %> recent order<%= recentOrders.length !== 1 ? 's' : '' %></span>
          <% } else { %>
          <span class="acct-link__sub">No orders yet</span>
          <% } %>
        </div>
        <i data-lucide="chevron-right" class="acct-link__arrow"></i>
      </a>

      <a href="/my-wallet" class="acct-link">
        <div class="acct-link__icon">
          <i data-lucide="credit-card"></i>
        </div>
        <div class="acct-link__body">
          <span class="acct-link__label">My Wallet</span>
          <!-- <% if (totalTopups > 0) { %>
          <span class="acct-link__sub"><%= totalTopups %> completed topup<%= totalTopups !== 1 ? 's' : '' %></span>
          <% } else { %>
          <span class="acct-link__sub">No topups yet</span>
          <% } %> -->
        </div>
        <i data-lucide="chevron-right" class="acct-link__arrow"></i>
      </a>

       <a href="/my-topUps" class="acct-link">
        <div class="acct-link__icon">
          <i data-lucide="credit-card"></i>
        </div>
        <div class="acct-link__body">
          <span class="acct-link__label">Topup History</span>
          <% if (totalTopups > 0) { %>
          <span class="acct-link__sub"><%= totalTopups %> completed topup<%= totalTopups !== 1 ? 's' : '' %></span>
          <% } else { %>
          <span class="acct-link__sub">No topups yet</span>
          <% } %>
        </div>
        <i data-lucide="chevron-right" class="acct-link__arrow"></i>
      </a>

      <a href="/conversion-history" class="acct-link">
        <div class="acct-link__icon">
          <i data-lucide="arrow-left-right"></i>
        </div>
        <div class="acct-link__body">
          <span class="acct-link__label">Conversion History</span>
          <span class="acct-link__sub">USDT → Naira conversions</span>
        </div>
        <i data-lucide="chevron-right" class="acct-link__arrow"></i>
      </a>

      <% if (user.minerId) { %>
      <div class="acct-link acct-link--static">
        <div class="acct-link__icon">
          <i data-lucide="cpu"></i>
        </div>
        <div class="acct-link__body">
          <span class="acct-link__label">Miner ID</span>
          <span class="acct-link__sub"><%= user.minerId %></span>
        </div>
      </div>
      <% } %>

    </div>
  </div>

  <!-- ── Edit profile ─────────────────────────────────────── -->
  <div class="acct-section">
    <h3 class="acct-section__title">Edit Profile</h3>
    <div class="acct-card">
      <form action="/edit-user-profile" method="post" class="profile-form">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">

        <input type="hidden" name="email" value="<%= user.email %>">

        <div class="form-group">
          <label class="form-label">Full Name</label>
          <div class="input-wrapper">
            <i data-lucide="user"></i>
            <input type="text" id="usernameInput" name="username" value="<%= user.username %>" class="form-input"
              pattern="[A-Za-z\s]+" title="Full name can only contain letters and spaces" required>
          </div>
        </div>

        

        <div class="form-group">
          <label class="form-label">Miner ID <span style="font-weight:400;color:var(--color-muted);">(optional)</span></label>
          <div class="input-wrapper">
            <i data-lucide="cpu"></i>
            <input type="text" name="minerId" value="<%= user.minerId || '' %>" class="form-input" placeholder="8 to 11 digit miner ID" pattern="[0-9]{10,11}" title="Miner ID must be exactly 8 to 11 digits" maxlength="11" minlength="8" inputmode="numeric">
          </div>
        </div>





        <button type="submit" class="btn btn--primary btn--full" style="margin-top:4px;">
          <i data-lucide="save"></i>
          Save Changes
        </button>

      </form>
    </div>
  </div>


  <!-- -- Change password -------------------------------- -->
  <div class="acct-section">
    <h3 class="acct-section__title">Security</h3>
    <div class="acct-links">
      <a href="/user/profile-change-password" class="acct-link">
        <div class="acct-link__icon">
          <i data-lucide="key-round"></i>
        </div>
        <div class="acct-link__body">
          <span class="acct-link__label">Change Password</span>
          <span class="acct-link__sub">A verification code will be sent to your email</span>
        </div>
        <i data-lucide="chevron-right" class="acct-link__arrow"></i>
      </a>
    </div>
  </div>
  <!-- ── Logout ───────────────────────────────────────────── -->
  <div class="acct-section">
    <a href="/user/logout" class="btn btn--danger btn--full">
      <i data-lucide="log-out"></i>
      Log Out
    </a>
  </div>

</div>
</div>

<script>
(function() {
  var input = document.getElementById('usernameInput');
  if (!input) return;
  input.addEventListener('input', function() {
    var pos = this.selectionStart;
    var cleaned = this.value.replace(/[^A-Za-z\s]/g, '');
    if (cleaned !== this.value) {
      this.value = cleaned;
      this.setSelectionRange(pos - 1, pos - 1);
    }
  });
  input.addEventListener('keydown', function(e) {
    if (e.key.length === 1 && /[^A-Za-z\s]/.test(e.key)) {
      e.preventDefault();
    }
  });
})();
</script>
