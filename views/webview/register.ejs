<script>
/* ── Password visibility toggles ─────────────────────── */
(function() {
  document.querySelectorAll('.pw-toggle').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var input = document.getElementById(btn.getAttribute('data-target'));
      if (!input) return;
      var show = input.type === 'password';
      input.type = show ? 'text' : 'password';
      btn.querySelector('.pw-toggle__show').style.display = show ? 'none' : '';
      btn.querySelector('.pw-toggle__hide').style.display = show ? ''     : 'none';
    });
  });
})();

/* ── Password strength meter ──────────────────────────── */
(function() {
  var input    = document.getElementById('password');
  var meter    = document.getElementById('pwStrength');
  var label    = document.getElementById('pwStrengthLabel');
  var levels   = ['', 'pw-strength--weak', 'pw-strength--fair', 'pw-strength--good', 'pw-strength--strong'];
  var names    = ['', 'Weak', 'Fair', 'Good', 'Strong'];

  function score(pw) {
    if (!pw) return 0;
    var s = 0;
    if (pw.length >= 8)           s++;
    if (pw.length >= 12)          s++;
    if (/[A-Z]/.test(pw))         s++;
    if (/[0-9]/.test(pw))         s++;
    if (/[^A-Za-z0-9]/.test(pw))  s++;
    /* map 0-5 score → 1-4 levels */
    if (s <= 1) return 1;
    if (s === 2) return 2;
    if (s === 3) return 3;
    return 4;
  }

  if (!input || !meter || !label) return;

  input.addEventListener('input', function() {
    var pw  = input.value;
    var lvl = pw.length ? score(pw) : 0;

    /* toggle visibility */
    meter.classList.toggle('visible', lvl > 0);

    /* remove all level classes then apply current */
    levels.forEach(function(c) { if (c) meter.classList.remove(c); });
    if (lvl > 0) meter.classList.add(levels[lvl]);

    label.textContent = names[lvl] || '';
  });
})();

/* ── Refresh math captcha ─────────────────────────────── */
document.getElementById('refreshCaptcha').addEventListener('click', async function() {
  var btn = this;
  btn.style.opacity = '0.4';
  btn.style.pointerEvents = 'none';
  try {
    var res  = await fetch('/user/refresh-captcha?type=signup');
    var data = await res.json();
    document.getElementById('mathQuestion').textContent = data.question + ' = ?';
    document.getElementById('mathAnswer').value = '';
  } catch (e) { /* silently ignore */ }
  btn.style.opacity = '';
  btn.style.pointerEvents = '';
});

/* ── Form submit validation ───────────────────────────── */
document.getElementById('signupForm').addEventListener('submit', function(e) {
  var username        = document.querySelector('input[name="username"]').value.trim();
  var password        = document.getElementById('password').value;
  var confirmPassword = document.getElementById('confirm_password').value;
  var phoneCode       = document.getElementById('phoneCode').value;
  var phoneLocal      = document.getElementById('phoneLocal').value.trim();

  if (/\d/.test(username)) {
    e.preventDefault();
    Swal.fire({ icon: 'error', text: 'Full Name cannot contain numbers.' });
    return;
  }

  if (!phoneLocal) {
    e.preventDefault();
    Swal.fire({ icon: 'error', text: 'Please enter your phone number.' });
    return;
  }

  document.getElementById('phoneNumber').value = phoneCode + phoneLocal;

  if (password.length < 8) {
    e.preventDefault();
    Swal.fire({ icon: 'error', text: 'Password must be at least 8 characters long.' });
    return;
  }

  if (password !== confirmPassword) {
    e.preventDefault();
    Swal.fire({ icon: 'error', text: 'Passwords do not match.' });
  }
});
</script>
