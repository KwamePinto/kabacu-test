<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta content="width=device-width, initial-scale=1, maximum-scale=1, shrink-to-fit=no" name="viewport">
  <title>Kabacu Admin — Forgot Password</title>
  <link rel="stylesheet" href="/admin/assets/css/app.min.css">
  <link rel="stylesheet" href="/admin/assets/css/style.css">
  <link rel="stylesheet" href="/admin/assets/css/components.css">
  <link rel="stylesheet" href="/admin/assets/css/custom.css">
  <link rel="shortcut icon" type="image/x-icon" href="/assets/images/favicon.ico" />
  <style>
    body { background: #f0f4f8; }
    .login-brand { text-align: center; margin-bottom: 28px; }
    .login-brand img { height: 48px; width: auto; }
    .login-brand-title {
      margin: 10px 0 0;
      font-size: 13px;
      font-weight: 600;
      letter-spacing: .08em;
      text-transform: uppercase;
      color: #6b7280;
    }
    .login-wrap {
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 32px 16px;
    }
    .login-box { width: 100%; max-width: 400px; }
    .card { border: none; border-radius: 12px; box-shadow: 0 4px 24px rgba(0,0,0,.08); }
    .card-header {
      background: #47c363;
      border-radius: 12px 12px 0 0 !important;
      padding: 20px 28px;
      border: none;
    }
    .card-header h4 { color: #fff; font-size: 17px; font-weight: 700; margin: 0; }
    .card-body { padding: 28px; }
    .login-footer {
      text-align: center;
      margin-top: 20px;
      font-size: 12px;
      color: #9ca3af;
    }
    .btn-request {
      background: #47c363 !important;
      border-color: #47c363 !important;
      transition: all 0.3s ease;
      color: #fff;
    }
    .btn-request:hover {
      background: #2db157 !important;
      border-color: #2db157 !important;
      color: #fff;
    }
  </style>
</head>
<body>
  <div class="loader"></div>
  <div id="app">
    <div class="login-wrap">
      <div class="login-box">

        <div class="login-brand">
          <img src="/assets/images/new.PNG" alt="Kabacu">
          <p class="login-brand-title">Admin Portal</p>
        </div>

        <div class="card">
          <div class="card-header">
            <h4>Forgot Password</h4>
          </div>
          <div class="card-body">

            <% if (typeof query !== 'undefined' && query.sent == '1') { %>
            <div class="alert alert-success" style="font-size:13px;border-radius:6px;padding:12px 16px;margin-bottom:18px;">
              <strong>Request submitted.</strong> If an account with that email exists, a super admin will review your request and send a reset link to your email.
            </div>
            <% } %>

            <% if (typeof query !== 'undefined' && query.error == '1') { %>
            <div class="alert alert-danger" style="font-size:13px;border-radius:6px;padding:10px 14px;margin-bottom:18px;">
              Something went wrong. Please try again.
            </div>
            <% } %>

            <% if (!(typeof query !== 'undefined' && query.sent == '1')) { %>
            <p style="font-size:13px;color:#6b7280;margin-bottom:20px;line-height:1.6;">
              Enter your admin email address. A super admin will review your request and send you a password reset link.
            </p>
            <form method="POST" action="/admin/forgot-password">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">

              <div class="form-group">
                <label for="email" style="font-size:13px;font-weight:600;">Email Address</label>
                <input id="email" type="email" class="form-control" name="email" required autofocus placeholder="admin@kabacu.com">
              </div>

              <div class="form-group mt-4 mb-0">
                <button type="submit" class="btn btn-lg btn-block btn-request"
                  style="font-weight:700;border-radius:8px;">
                  Submit Request
                </button>
              </div>
            </form>
            <% } %>

            <div style="text-align:center;margin-top:20px;">
              <a href="/command" style="font-size:13px;color:#6b7280;text-decoration:none;">
                &larr; Back to Login
              </a>
            </div>
          </div>
        </div>

        <div class="login-footer">
          &copy; <%= new Date().getFullYear() %> Kabacu. All rights reserved.
        </div>

      </div>
    </div>
  </div>

  <script src="/admin/assets/js/app.min.js"></script>
  <script src="/admin/assets/js/scripts.js"></script>
  <script src="/admin/assets/js/custom.js"></script>
</body>
</html>
