<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta content="width=device-width, initial-scale=1, maximum-scale=1, shrink-to-fit=no" name="viewport">
  <title>Kabacu Admin Portal</title>
  <link rel="stylesheet" href="/admin/assets/css/app.min.css">
  <link rel="stylesheet" href="/admin/assets/css/style.css">
  <link rel="stylesheet" href="/admin/assets/css/components.css">
  <link rel="stylesheet" href="/admin/assets/css/custom.css">
  <link rel="shortcut icon" type="image/x-icon" href="/assets/images/favicon.ico" />
  <style>
    body { background: #f0f4f8; }
    .login-brand { text-align: center; margin-bottom: 28px; }
    .login-brand img { height: 48px; width: auto; }
    .login-brand-title {
      margin: 10px 0 0;
      font-size: 13px;
      font-weight: 600;
      letter-spacing: .08em;
      text-transform: uppercase;
      color: #6b7280;
    }
    .login-wrap {
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 32px 16px;
    }
    .login-box { width: 100%; max-width: 400px; }
    .card { border: none; border-radius: 12px; box-shadow: 0 4px 24px rgba(0,0,0,.08); }
    .card-header {
      background: #47c363;
      border-radius: 12px 12px 0 0 !important;
      padding: 20px 28px;
      border: none;
    }
    .card-header h4 { color: #fff; font-size: 17px; font-weight: 700; margin: 0; }
    .card-body { padding: 28px; }
    .login-footer {
      text-align: center;
      margin-top: 20px;
      font-size: 12px;
      color: #9ca3af;
    }
  </style>
</head>

<body>
  <div class="loader"></div>
  <div id="app">
    <div class="login-wrap">
      <div class="login-box">

        <div class="login-brand">
          <img src="/assets/images/new.PNG" alt="Kabacu">
          <p class="login-brand-title">Admin Portal</p>
        </div>

        <div class="card">
          <div class="card-header">
            <h4>Sign In</h4>
          </div>
          <div class="card-body">
            <div id="resetSuccessAlert" class="alert alert-success" style="font-size:13px;border-radius:6px;padding:10px 14px;margin-bottom:18px;display:none;">
              <i class="fas fa-check-circle mr-1"></i> Password reset successfully. You can now log in with your new password.
            </div>

            <% if (typeof error !== 'undefined' && error) { %>
            <div class="alert alert-danger" style="font-size:13px;border-radius:6px;padding:10px 14px;margin-bottom:18px;">
              <i class="fas fa-exclamation-circle mr-1"></i> <%= error %>
            </div>
            <% } %>

            <form method="POST" action="/admin/user/login" class="needs-validation" novalidate="">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">

              <div class="form-group">
                <label for="email">Email Address</label>
                <input id="email" type="email" class="form-control" name="email" tabindex="1" required autofocus placeholder="admin@kabacu.com">
                <div class="invalid-feedback">Please enter your email</div>
              </div>

              <div class="form-group">
                <label for="password">Password</label>
                <div style="position:relative;">
                  <input id="password" type="password" class="form-control" name="password" tabindex="2" required placeholder="••••••••" style="padding-right:44px;">
                  <button type="button" id="toggleAdminPw" tabindex="-1"
                    style="position:absolute;right:0;top:0;height:100%;width:42px;background:none;border:none;cursor:pointer;color:#6b7280;display:flex;align-items:center;justify-content:center;"
                    aria-label="Toggle password visibility">
                    <svg id="eyeShow" xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                    <svg id="eyeHide" xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none;"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/></svg>
                  </button>
                </div>
                <div class="invalid-feedback">Please enter your password</div>
              </div>

              <div class="form-group">
                <label for="role">Role</label>
                <select id="role" class="form-control selectric" name="role" tabindex="3">
                  <option value="super_admin">Super Admin</option>
                  <option value="senior_admin">Senior Admin</option>
                  <option value="junior_admin">Junior Admin</option>
                </select>
              </div>

              <div class="form-group mt-4 mb-0">
                <button type="submit" class="btn btn-primary btn-lg btn-block" tabindex="4"
                  style="background:#47c363;border-color:#47c363;font-weight:700;border-radius:8px;">
                  Sign In
                </button>
              </div>
            </form>

            <div style="text-align:center;margin-top:16px;">
              <a href="/admin/user/forgot-password" style="font-size:13px;color:#6b7280;text-decoration:none;">
                Forgot password?
              </a>
            </div>
          </div>
        </div>

        <div class="login-footer">
          &copy; <%= new Date().getFullYear() %> Kabacu. All rights reserved.
        </div>

      </div>
    </div>
  </div>

  <script src="/admin/assets/js/app.min.js"></script>
  <script src="/admin/assets/js/scripts.js"></script>
  <script src="/admin/assets/js/custom.js"></script>
  <script>
    if (new URLSearchParams(window.location.search).get('passwordReset') === '1') {
      document.getElementById('resetSuccessAlert').style.display = 'block';
    }

    document.getElementById('toggleAdminPw').addEventListener('click', function () {
      var input   = document.getElementById('password');
      var show    = input.type === 'password';
      input.type  = show ? 'text' : 'password';
      document.getElementById('eyeShow').style.display = show ? 'none' : '';
      document.getElementById('eyeHide').style.display = show ? ''     : 'none';
    });
  </script>
</body>
</html>
