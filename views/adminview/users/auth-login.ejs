<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta content="width=device-width, initial-scale=1, maximum-scale=1, shrink-to-fit=no" name="viewport">
  <title>Kabacu Admin Portal</title>
  <link rel="stylesheet" href="/admin/assets/css/app.min.css">
  <link rel="stylesheet" href="/admin/assets/css/style.css">
  <link rel="stylesheet" href="/admin/assets/css/components.css">
  <link rel="stylesheet" href="/admin/assets/css/custom.css">
  <link rel="shortcut icon" type="image/x-icon" href="/assets/images/favicon.ico" />
  <style>
    body { background: #f0f4f8; }
    .login-brand { text-align: center; margin-bottom: 28px; }
    .login-brand img { height: 48px; width: auto; }
    .login-brand-title {
      margin: 10px 0 0;
      font-size: 13px;
      font-weight: 600;
      letter-spacing: .08em;
      text-transform: uppercase;
      color: #6b7280;
    }
    .login-wrap {
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 32px 16px;
    }
    .login-box { width: 100%; max-width: 400px; }
    .card { border: none; border-radius: 12px; box-shadow: 0 4px 24px rgba(0,0,0,.08); }
    .card-header {
      background: #47c363;
      border-radius: 12px 12px 0 0 !important;
      padding: 20px 28px;
      border: none;
    }
    .card-header h4 { color: #fff; font-size: 17px; font-weight: 700; margin: 0; }
    .card-body { padding: 28px; }
    .login-footer {
      text-align: center;
      margin-top: 20px;
      font-size: 12px;
      color: #9ca3af;
    }
  </style>
</head>

<body>
  <div class="loader"></div>
  <div id="app">
    <div class="login-wrap">
      <div class="login-box">

        <div class="login-brand">
          <img src="/assets/images/new.PNG" alt="Kabacu">
          <p class="login-brand-title">Admin Portal</p>
        </div>

        <div class="card">
          <div class="card-header">
            <h4>Sign In</h4>
          </div>
          <div class="card-body">
            <form method="POST" action="/admin/user/login" class="needs-validation" novalidate="">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">

              <div class="form-group">
                <label for="email">Email Address</label>
                <input id="email" type="email" class="form-control" name="email" tabindex="1" required autofocus placeholder="admin@kabacu.com">
                <div class="invalid-feedback">Please enter your email</div>
              </div>

              <div class="form-group">
                <label for="password">Password</label>
                <input id="password" type="password" class="form-control" name="password" tabindex="2" required placeholder="••••••••">
                <div class="invalid-feedback">Please enter your password</div>
              </div>

              <div class="form-group">
                <label for="role">Role</label>
                <select id="role" class="form-control selectric" name="role" tabindex="3">
                  <option value="super_admin">Super Admin</option>
                  <option value="senior_admin">Senior Admin</option>
                  <option value="junior_admin">Junior Admin</option>
                </select>
              </div>

              <div class="form-group mt-4 mb-0">
                <button type="submit" class="btn btn-primary btn-lg btn-block" tabindex="4"
                  style="background:#47c363;border-color:#47c363;font-weight:700;border-radius:8px;">
                  Sign In
                </button>
              </div>
            </form>
          </div>
        </div>

        <div class="login-footer">
          &copy; <%= new Date().getFullYear() %> Kabacu. All rights reserved.
        </div>

      </div>
    </div>
  </div>

  <script src="/admin/assets/js/app.min.js"></script>
  <script src="/admin/assets/js/scripts.js"></script>
  <script src="/admin/assets/js/custom.js"></script>
</body>
</html>
