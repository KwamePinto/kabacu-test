<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta content="width=device-width, initial-scale=1, maximum-scale=1, shrink-to-fit=no" name="viewport">
  <title>Kabacu Admin — Reset Password</title>
  <link rel="stylesheet" href="/admin/assets/css/app.min.css">
  <link rel="stylesheet" href="/admin/assets/css/style.css">
  <link rel="stylesheet" href="/admin/assets/css/components.css">
  <link rel="stylesheet" href="/admin/assets/css/custom.css">
  <link rel="shortcut icon" type="image/x-icon" href="/assets/images/favicon.ico" />
  <style>
    body { background: #f0f4f8; }
    .login-brand { text-align: center; margin-bottom: 28px; }
    .login-brand img { height: 48px; width: auto; }
    .login-brand-title {
      margin: 10px 0 0;
      font-size: 13px;
      font-weight: 600;
      letter-spacing: .08em;
      text-transform: uppercase;
      color: #6b7280;
    }
    .login-wrap {
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 32px 16px;
    }
    .login-box { width: 100%; max-width: 400px; }
    .card { border: none; border-radius: 12px; box-shadow: 0 4px 24px rgba(0,0,0,.08); }
    .card-header {
      background: #47c363;
      border-radius: 12px 12px 0 0 !important;
      padding: 20px 28px;
      border: none;
    }
    .card-header h4 { color: #fff; font-size: 17px; font-weight: 700; margin: 0; }
    .card-body { padding: 28px; }
    .login-footer {
      text-align: center;
      margin-top: 20px;
      font-size: 12px;
      color: #9ca3af;
    }
    .pw-wrap { position: relative; }
    .pw-toggle-btn {
      position: absolute; right: 0; top: 0;
      height: 100%; width: 42px;
      background: none; border: none; cursor: pointer;
      color: #6b7280; display: flex; align-items: center; justify-content: center;
    }
  </style>
</head>
<body>
  <div class="loader"></div>
  <div id="app">
    <div class="login-wrap">
      <div class="login-box">

        <div class="login-brand">
          <img src="/assets/images/new.PNG" alt="Kabacu">
          <p class="login-brand-title">Admin Portal</p>
        </div>

        <div class="card">
          <div class="card-header">
            <h4>Reset Password</h4>
          </div>
          <div class="card-body">

            <% if (error) { %>
            <div class="alert alert-danger" style="font-size:13px;border-radius:6px;padding:10px 14px;margin-bottom:18px;">
              <%= error %>
            </div>
            <% } %>

            <% if (tokenValid) { %>
            <p style="font-size:13px;color:#6b7280;margin-bottom:20px;line-height:1.6;">
              Choose a new password for your account. Minimum 8 characters.
            </p>
            <form method="POST" action="/admin/user/reset-password" id="resetForm">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <input type="hidden" name="token" value="<%= token %>">

              <div class="form-group">
                <label style="font-size:13px;font-weight:600;">New Password</label>
                <div class="pw-wrap">
                  <input type="password" id="password" name="password" class="form-control" required minlength="8" placeholder="Min. 8 characters" style="padding-right:44px;">
                  <button type="button" class="pw-toggle-btn" data-target="password" tabindex="-1" aria-label="Toggle password">
                    <svg class="eye-show" xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                    <svg class="eye-hide" xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none;"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/></svg>
                  </button>
                </div>
              </div>

              <div class="form-group">
                <label style="font-size:13px;font-weight:600;">Confirm New Password</label>
                <div class="pw-wrap">
                  <input type="password" id="confirmPassword" name="confirmPassword" class="form-control" required minlength="8" placeholder="Repeat your password" style="padding-right:44px;">
                  <button type="button" class="pw-toggle-btn" data-target="confirmPassword" tabindex="-1" aria-label="Toggle password">
                    <svg class="eye-show" xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                    <svg class="eye-hide" xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none;"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/></svg>
                  </button>
                </div>
              </div>

              <div class="form-group mt-4 mb-0">
                <button type="submit" class="btn btn-primary btn-lg btn-block"
                  style="background:#47c363;border-color:#47c363;font-weight:700;border-radius:8px;">
                  Set New Password
                </button>
              </div>
            </form>
            <% } else { %>
            <div style="text-align:center;padding:12px 0;">
              <a href="/admin/user/forgot-password" class="btn btn-primary"
                style="background:#47c363;border-color:#47c363;font-weight:700;border-radius:8px;">
                Request a New Reset Link
              </a>
            </div>
            <% } %>

            <div style="text-align:center;margin-top:20px;">
              <a href="/admin/user/login" style="font-size:13px;color:#6b7280;text-decoration:none;">
                &larr; Back to Login
              </a>
            </div>
          </div>
        </div>

        <div class="login-footer">
          &copy; <%= new Date().getFullYear() %> Kabacu. All rights reserved.
        </div>

      </div>
    </div>
  </div>

  <script src="/admin/assets/js/app.min.js"></script>
  <script src="/admin/assets/js/scripts.js"></script>
  <script src="/admin/assets/js/custom.js"></script>
  <script>
  document.querySelectorAll('.pw-toggle-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var input = document.getElementById(btn.getAttribute('data-target'));
      if (!input) return;
      var show = input.type === 'password';
      input.type = show ? 'text' : 'password';
      btn.querySelector('.eye-show').style.display = show ? 'none' : '';
      btn.querySelector('.eye-hide').style.display = show ? ''     : 'none';
    });
  });

  var resetForm = document.getElementById('resetForm');
  if (resetForm) {
    resetForm.addEventListener('submit', function(e) {
      var pw  = document.getElementById('password').value;
      var cpw = document.getElementById('confirmPassword').value;
      if (pw !== cpw) {
        e.preventDefault();
        alert('Passwords do not match.');
      }
    });
  }
  </script>
</body>
</html>
