
  <div class="loader"></div>
  <div id="app">
    <div class="main-wrapper main-wrapper-1">
      <div class="navbar-bg"></div>
      <%- include('../../partials/headerAdmin.ejs') %>
      <%- include('../../partials/sideMenuAdmin.ejs') %>

      <div class="main-content">
        <section class="section">
          <div class="section-header">
            <h1>Admins</h1>
            <div class="section-header-breadcrumb">
              <div class="breadcrumb-item"><a href="/admin/main/dashboard">Dashboard</a></div>
              <div class="breadcrumb-item active">Admins</div>
            </div>
          </div>

          <div class="section-body">

            <% if (typeof query !== 'undefined' && query.success == '1') { %>
            <div class="alert alert-success alert-dismissible fade show" role="alert">
              Admin added successfully. Login credentials have been sent to their email.
              <button type="button" class="close" data-dismiss="alert">&times;</button>
            </div>
            <% } %>

            <div class="card">
              <div class="card-header">
                <h4>All Administrators</h4>
                <div class="card-header-action">
                  <% if (user && (user.role === 'super_admin' || user.role === 'senior_admin')) { %>
                  <a href="/admin/user/admins/add" class="btn btn-primary">
                    <i data-feather="user-plus" style="width:14px;height:14px;margin-right:4px;"></i> Add Admin
                  </a>
                  <% } %>
                </div>
              </div>
              <div class="card-body p-0">
                <div class="table-responsive">
                  <table class="table table-striped table-hover mb-0">
                    <thead>
                      <tr>
                        <th>#</th>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Role</th>
                        <th>Department</th>
                        <th>Added By</th>
                        <th>Joined</th>
                        <th>Profile</th>
                      </tr>
                    </thead>
                    <tbody>
                      <% if (admins && admins.length) { %>
                        <% admins.forEach(function(admin, i) { %>
                        <tr>
                          <td><%= i + 1 %></td>
                          <td>
                            <div style="display:flex;align-items:center;gap:8px;">
                              <div style="width:32px;height:32px;border-radius:50%;background:#47c363;display:flex;align-items:center;justify-content:center;color:#fff;font-weight:700;font-size:13px;flex-shrink:0;">
                                <%= admin.username.charAt(0).toUpperCase() %>
                              </div>
                              <span><%= admin.username %></span>
                            </div>
                          </td>
                          <td><%= admin.email %></td>
                          <td>
                            <% const roleColors = { super_admin: 'badge-danger', senior_admin: 'badge-warning', junior_admin: 'badge-info' }; %>
                            <span class="badge <%= roleColors[admin.role] || 'badge-secondary' %>" style="font-size:11px;padding:4px 8px;">
                              <%= admin.role.replace(/_/g, ' ') %>
                            </span>
                          </td>
                          <td><%= admin.department || '<span class="text-muted">—</span>' %></td>
                          <td>
                            <% if (admin.addedBy) { %>
                              <%= admin.addedBy.username %>
                            <% } else { %>
                              <span class="text-muted">—</span>
                            <% } %>
                          </td>
                          <td style="font-size:12px;color:#6b7280;">
                            <%= admin.createdAt ? new Date(admin.createdAt).toLocaleDateString('en-GB', { day:'2-digit', month:'short', year:'numeric' }) : '—' %>
                          </td>
                          <td>
                            <% if (admin.profileCompleted) { %>
                              <span class="badge badge-success" style="font-size:11px;">Complete</span>
                            <% } else { %>
                              <span class="badge badge-secondary" style="font-size:11px;">Pending</span>
                            <% } %>
                          </td>
                        </tr>
                        <% }) %>
                      <% } else { %>
                        <tr>
                          <td colspan="8" class="text-center py-4 text-muted">No admins found.</td>
                        </tr>
                      <% } %>
                    </tbody>
                  </table>
                </div>
              </div>
            </div>

          </div>
        </section>
      </div>

      <footer class="main-footer">
        <div class="footer-left">
          &copy; <%= new Date().getFullYear() %> Kabacu. All rights reserved.
        </div>
        <div class="footer-right"></div>
      </footer>
    </div>
  </div>
