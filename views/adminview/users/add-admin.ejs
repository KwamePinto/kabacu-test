<div class="loader"></div>
<div id="app">
  <div class="main-wrapper main-wrapper-1">
    <div class="navbar-bg"></div>
    <%- include('../../partials/headerAdmin.ejs') %>
    <%- include('../../partials/sideMenuAdmin.ejs') %>

    <div class="main-content">
      <section class="section">
        <div class="section-header">
          <h1>Add Admin</h1>
          <div class="section-header-breadcrumb">
            <div class="breadcrumb-item"><a href="/admin/main/dashboard">Dashboard</a></div>
            <div class="breadcrumb-item"><a href="/admin/user/admins">Admins</a></div>
            <div class="breadcrumb-item active">Add Admin</div>
          </div>
        </div>

        <div class="section-body">
          <div class="row">
            <div class="col-12 col-lg-7 mx-auto">
              <div class="card">
                <div class="card-header">
                  <h4>New Administrator</h4>
                </div>
                <div class="card-body">

                  <div class="alert alert-info mb-4" style="font-size:13px;">
                    <i data-feather="info" style="width:14px;height:14px;margin-right:4px;vertical-align:middle;"></i>
                    A secure 10-character password will be generated automatically and sent to the admin's email address along with their login details.
                  </div>

                  <div id="formError" class="alert alert-danger" style="display:none;font-size:13px;"></div>

                  <form id="addAdminForm" method="post" action="/admin/user/admins/add">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">

                    <div class="form-group">
                      <label>Full Name <span class="text-danger">*</span></label>
                      <input type="text" name="username" class="form-control" placeholder="e.g. John Doe" required>
                    </div>

                    <div class="form-group">
                      <label>Email Address <span class="text-danger">*</span></label>
                      <input type="email" name="email" class="form-control" placeholder="admin@example.com" required>
                    </div>

                    <div class="form-group">
                      <label>Role <span class="text-danger">*</span></label>
                      <select name="role" class="form-control" required>
                        <option value="">Select a role</option>
                        <option value="senior_admin">Senior Admin</option>
                        <option value="junior_admin">Junior Admin</option>
                        <% if (user && user.role === 'super_admin') { %>
                        <option value="super_admin">Super Admin</option>
                        <% } %>
                      </select>
                      <small class="text-muted">
                        <strong>Junior Admin</strong> — limited access. &nbsp;
                        <strong>Senior Admin</strong> — full access except admin management.
                      </small>
                    </div>

                    <div class="card-footer text-right px-0 pb-0 mt-3" style="border-top:none;">
                      <a href="/admin/user/admins" class="btn btn-secondary mr-2">Cancel</a>
                      <button type="submit" class="btn btn-primary" id="submitBtn">
                        <span id="submitLabel">Add Admin &amp; Send Credentials</span>
                        <span id="submitSpinner" style="display:none;">
                          <span class="spinner-border spinner-border-sm mr-1" role="status"></span> Sending…
                        </span>
                      </button>
                    </div>
                  </form>

                </div>
              </div>
            </div>
          </div>
        </div>
      </section>
    </div>

    <footer class="main-footer">
      <div class="footer-left">
        &copy; <%= new Date().getFullYear() %> Kabacu. All rights reserved.
      </div>
      <div class="footer-right"></div>
    </footer>
  </div>
</div>

<script>
  (function() {
    var form = document.getElementById('addAdminForm');
    var submitBtn = document.getElementById('submitBtn');
    var submitLbl = document.getElementById('submitLabel');
    var submitSpn = document.getElementById('submitSpinner');
    var errorBox = document.getElementById('formError');

    form.addEventListener('submit', function(e) {
      e.preventDefault();
      errorBox.style.display = 'none';
      submitBtn.disabled = true;
      submitLbl.style.display = 'none';
      submitSpn.style.display = 'inline';

      var data = new FormData(form);
      var body = new URLSearchParams(data).toString();

      fetch('/admin/user/admins/add', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/x-www-form-urlencoded'
        },
        body: body,
        redirect: 'follow',
      }).then(function(res) {
        if (res.redirected) {
          window.location.href = res.url;
          return;
        }
        return res.json().then(function(json) {
          errorBox.textContent = json.error || 'An error occurred. Please try again.';
          errorBox.style.display = 'block';
          submitBtn.disabled = false;
          submitLbl.style.display = 'inline';
          submitSpn.style.display = 'none';
        });
      }).catch(function() {
        errorBox.textContent = 'Network error. Please try again.';
        errorBox.style.display = 'block';
        submitBtn.disabled = false;
        submitLbl.style.display = 'inline';
        submitSpn.style.display = 'none';
      });
    });
  }());
</script>