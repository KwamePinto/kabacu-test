<div class="loader"></div>
<div id="app">
  <div class="main-wrapper main-wrapper-1">
    <div class="navbar-bg"></div>
    <%- include('../partials/headerAdmin.ejs') %>
    <%- include('../partials/sideMenuAdmin.ejs') %>

    <div class="main-content">
      <section class="section">

        <div class="section-header">
          <h1>Data Networks</h1>
          <div class="section-header-breadcrumb">
            <div class="breadcrumb-item active"><a href="/admin/main/dashboard">Dashboard</a></div>
            <div class="breadcrumb-item"><a href="/admin/product/view-products">Products</a></div>
            <div class="breadcrumb-item">Networks</div>
          </div>
        </div>

        <div class="section-body">
          <div class="row">

            <!-- ── Add Network ──────────────────────────────── -->
            <div class="col-12 col-lg-4 mb-4">
              <div class="card h-100">
                <div class="card-header">
                  <h4>Add Network</h4>
                </div>
                <div class="card-body">

                  <% if (query.added == '1') { %>
                  <div class="alert alert-success alert-dismissible fade show">
                    Network added successfully.
                    <button type="button" class="close" data-dismiss="alert">&times;</button>
                  </div>
                  <% } %>
                  <% if (query.deleted == '1') { %>
                  <div class="alert alert-success alert-dismissible fade show">
                    Network removed.
                    <button type="button" class="close" data-dismiss="alert">&times;</button>
                  </div>
                  <% } %>
                  <% if (query.error == 'duplicate') { %>
                  <div class="alert alert-warning alert-dismissible fade show">
                    A network with that name already exists.
                    <button type="button" class="close" data-dismiss="alert">&times;</button>
                  </div>
                  <% } else if (query.error) { %>
                  <div class="alert alert-danger alert-dismissible fade show">
                    Something went wrong. Please try again.
                    <button type="button" class="close" data-dismiss="alert">&times;</button>
                  </div>
                  <% } %>

                  <form method="post" action="/admin/networks/add">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">

                    <div class="form-group">
                      <label class="net-label">Network Name</label>
                      <p class="net-hint">The exact name that will appear on products and be stored in the database.</p>
                      <input type="text" name="name" class="form-control"
                        placeholder="e.g. MTN Awoof, CTC Awoof Daily"
                        required maxlength="60">
                    </div>

                    <div class="form-group">
                      <label class="net-label">API Provider</label>
                      <p class="net-hint">The underlying carrier this network routes through.</p>
                      <select name="apiCode" class="form-control" required>
                        <option value="" disabled selected>Select provider…</option>
                        <option value="1">MTN</option>
                        <option value="2">GLO</option>
                        <option value="3">Airtel</option>
                        <option value="4">9mobile</option>
                      </select>
                    </div>

                    <button type="submit" class="btn btn-primary btn-block mt-3">Add Network</button>
                  </form>
                </div>
              </div>
            </div>

            <!-- ── Network List ─────────────────────────────── -->
            <div class="col-12 col-lg-8 mb-4">
              <div class="card">
                <div class="card-header">
                  <h4>Configured Networks</h4>
                  <div class="card-header-action">
                    <span class="badge badge-primary" style="font-size:13px;padding:6px 12px;">
                      <%= networks.length %> network<%= networks.length !== 1 ? 's' : '' %>
                    </span>
                  </div>
                </div>
                <div class="card-body p-0">
                  <% if (!networks.length) { %>
                  <div class="text-center py-5 text-muted">
                    <i data-feather="wifi-off" style="width:40px;height:40px;opacity:.3;display:block;margin:0 auto 12px;"></i>
                    No networks configured yet. Add one to get started.
                  </div>
                  <% } else { %>
                  <div class="table-responsive">
                    <table class="table table-hover mb-0">
                      <thead style="background:#f9fafb;">
                        <tr>
                          <th style="padding:14px 20px;font-size:11px;text-transform:uppercase;letter-spacing:.6px;color:#9ca3af;font-weight:700;">Network Name</th>
                          <th style="padding:14px 20px;font-size:11px;text-transform:uppercase;letter-spacing:.6px;color:#9ca3af;font-weight:700;">API Provider</th>
                          <th style="padding:14px 20px;font-size:11px;text-transform:uppercase;letter-spacing:.6px;color:#9ca3af;font-weight:700;">Code</th>
                          <th></th>
                        </tr>
                      </thead>
                      <tbody>
                        <% networks.forEach(net => { %>
                        <% const providerColors = { 1: '#fbbf24', 2: '#22c55e', 3: '#ef4444', 4: '#3b82f6' }; %>
                        <tr>
                          <td style="padding:14px 20px;font-weight:600;font-size:14px;"><%= net.name %></td>
                          <td style="padding:14px 20px;">
                            <span class="net-provider-badge" style="background:<%= providerColors[net.apiCode] %>20;color:<%= providerColors[net.apiCode] %>;">
                              <%= providerLabels[net.apiCode] %>
                            </span>
                          </td>
                          <td style="padding:14px 20px;color:#9ca3af;font-family:monospace;"><%= net.apiCode %></td>
                          <td style="padding:14px 20px;text-align:right;">
                            <form method="post" action="/admin/networks/delete/<%= net._id %>" class="d-inline" onsubmit="return confirmDelete(this)">
                              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                              <button type="submit" class="btn btn-sm btn-outline-danger" style="border-radius:20px;">Remove</button>
                            </form>
                          </td>
                        </tr>
                        <% }) %>
                      </tbody>
                    </table>
                  </div>
                  <% } %>
                </div>
              </div>
            </div>

          </div>
        </div>
      </section>

      <div class="settingSidebar">
        <a href="javascript:void(0)" class="settingPanelToggle"><i class="fa fa-spin fa-cog"></i></a>
        <div class="settingSidebar-body ps-container ps-theme-default">
          <div class="fade show active">
            <div class="setting-panel-header">Setting Panel</div>
            <div class="p-15 border-bottom">
              <h6 class="font-medium m-b-10">Select Layout</h6>
              <div class="selectgroup layout-color w-50">
                <label class="selectgroup-item">
                  <input type="radio" name="value" value="1" class="selectgroup-input-radio select-layout" checked>
                  <span class="selectgroup-button">Light</span>
                </label>
                <label class="selectgroup-item">
                  <input type="radio" name="value" value="2" class="selectgroup-input-radio select-layout">
                  <span class="selectgroup-button">Dark</span>
                </label>
              </div>
            </div>
            <div class="mt-4 mb-4 p-3 align-center rt-sidebar-last-ele">
              <a href="#" class="btn btn-icon icon-left btn-primary btn-restore-theme">
                <i class="fas fa-undo"></i> Restore Default
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>

    <footer class="main-footer">
      <div class="footer-left">&copy; <%= new Date().getFullYear() %> Kabacu. All rights reserved.</div>
      <div class="footer-right"></div>
    </footer>
  </div>
</div>

<style>
.net-label { font-size: 13px; font-weight: 600; color: #374151; margin-bottom: 4px; display: block; }
.net-hint  { font-size: 12px; color: #9ca3af; margin-bottom: 8px; }
.net-provider-badge {
  display: inline-block; font-size: 12px; font-weight: 700;
  padding: 3px 10px; border-radius: 20px; letter-spacing: .3px;
}
</style>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
function confirmDelete(form) {
  Swal.fire({
    title: 'Remove Network?',
    text: 'Products using this network name will still work, but it will no longer appear in the dropdown.',
    icon: 'warning',
    showCancelButton: true,
    confirmButtonText: 'Yes, Remove',
    confirmButtonColor: '#ef4444',
    cancelButtonText: 'Cancel',
  }).then(r => { if (r.isConfirmed) form.submit(); });
  return false;
}
</script>
