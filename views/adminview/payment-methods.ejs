
  <div class="loader"></div>
  <div id="app">
    <div class="main-wrapper main-wrapper-1">
      <div class="navbar-bg"></div>

      <%- include('../partials/headerAdmin.ejs') %>
      <%- include('../partials/sideMenuAdmin.ejs') %>

      <div class="main-content">
        <section class="section">
          <div class="section-body">

            <div class="row">
              <div class="col-12 col-md-5">
                <div class="card">
                  <div class="card-header"><h4>Add Payment Method</h4></div>
                  <div class="card-body">
                    <form method="POST" action="/admin/product/payment-methods/add">
                      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                      <div class="form-group">
                        <label>Method Name</label>
                        <input type="text" name="name" class="form-control" placeholder="e.g. PalmPay, Flutterwave" required>
                      </div>
                      <button type="submit" class="btn btn-primary btn-block">Add Method</button>
                    </form>
                  </div>
                </div>
              </div>

              <div class="col-12 col-md-7">
                <div class="card">
                  <div class="card-header"><h4>Payment Methods</h4></div>
                  <div class="card-body p-0">
                    <div class="table-responsive">
                      <table class="table table-striped mb-0">
                        <thead>
                          <tr>
                            <th>#</th>
                            <th>Name</th>
                            <th>Status</th>
                            <th>Added</th>
                            <th>Actions</th>
                          </tr>
                        </thead>
                        <tbody>
                          <% if (methods.length > 0) { %>
                            <% methods.forEach((m, i) => { %>
                              <tr>
                                <td><%= i + 1 %></td>
                                <td><b><%= m.name %></b></td>
                                <td>
                                  <% if (m.isActive) { %>
                                    <span class="badge badge-success">Active</span>
                                  <% } else { %>
                                    <span class="badge badge-secondary">Inactive</span>
                                  <% } %>
                                </td>
                                <td><small><%= new Date(m.createdAt).toLocaleDateString('en-GB', { day:'2-digit', month:'short', year:'numeric' }) %></small></td>
                                <td>
                                  <a href="/admin/product/payment-methods/toggle/<%= m._id %>" class="btn btn-sm <%= m.isActive ? 'btn-warning' : 'btn-success' %>">
                                    <%= m.isActive ? 'Deactivate' : 'Activate' %>
                                  </a>
                                  <a href="/admin/product/payment-methods/delete/<%= m._id %>"
                                     class="btn btn-sm btn-danger"
                                     onclick="return confirm('Delete <%= m.name %>?')">
                                    Delete
                                  </a>
                                </td>
                              </tr>
                            <% }) %>
                          <% } else { %>
                            <tr>
                              <td colspan="5" class="text-center py-4">No payment methods yet. Add one on the left.</td>
                            </tr>
                          <% } %>
                        </tbody>
                      </table>
                    </div>
                  </div>
                </div>
              </div>
            </div>

          </div>
        </section>
      </div>

      <%- include('../partials/footerAdmin.ejs') %>
    </div>
  </div>
  <script src="/admin/assets/js/app.min.js"></script>
  <script src="/admin/assets/js/scripts.js"></script>