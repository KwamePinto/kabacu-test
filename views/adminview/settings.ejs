
  <div class="loader"></div>
  <div id="app">
    <div class="main-wrapper main-wrapper-1">
      <div class="navbar-bg"></div>
      <%- include('../partials/headerAdmin.ejs')%>
      <%- include('../partials/sideMenuAdmin.ejs')%>

      <div class="main-content">
        <section class="section">
          <div class="section-body">
            <div class="row">
              <div class="col-12 col-lg-8 mx-auto">

                <% if (typeof query !== 'undefined' && query.saved == '1') { %>
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                  Settings saved successfully.
                  <button type="button" class="close" data-dismiss="alert">&times;</button>
                </div>
                <% } %>
                <% if (typeof query !== 'undefined' && query.error == '1') { %>
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                  An error occurred. Please try again.
                  <button type="button" class="close" data-dismiss="alert">&times;</button>
                </div>
                <% } %>

                <form method="post" action="/admin/settings" id="settingsForm">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">

                  <div class="card">
                    <div class="card-header" style="border-bottom:1px solid #f0f0f0;">
                      <h4 class="mb-0">
                        <i data-feather="sliders" style="width:18px;height:18px;margin-right:8px;vertical-align:middle;"></i>
                        Site Settings
                      </h4>
                    </div>
                    <div class="card-body p-0">

                      <!-- ── BitToken RP Transfer ────────────────────────────── -->
                      <div class="settings-group" id="group-bittoken">
                        <button type="button" class="settings-group__header" data-target="body-bittoken">
                          <div class="settings-group__title">
                            <span class="settings-group__icon settings-group__icon--blue">
                              <i data-feather="repeat"></i>
                            </span>
                            <div>
                              <span class="settings-group__label">BitToken RP Transfer</span>
                              <span class="settings-group__sub">Manage Reward Point transfer to BitToken</span>
                            </div>
                          </div>
                          <div class="settings-group__meta">
                            <span class="settings-badge <%= settings.rpTransferEnabled ? 'settings-badge--on' : 'settings-badge--off' %>" id="badge-rp">
                              <%= settings.rpTransferEnabled ? 'Enabled' : 'Disabled' %>
                            </span>
                            <i data-feather="chevron-down" class="settings-group__chevron"></i>
                          </div>
                        </button>
                        <div class="settings-group__body" id="body-bittoken">
                          <div class="settings-group__inner">

                            <div class="settings-row">
                              <div class="settings-row__text">
                                <span class="settings-row__label">Allow RP Transfer to BitToken</span>
                                <span class="settings-row__desc">When disabled, users will see a notice instead of the transfer option.</span>
                              </div>
                              <label class="custom-switch mb-0">
                                <input type="checkbox" id="rpTransferToggle" class="custom-switch-input"
                                  <%= settings.rpTransferEnabled ? 'checked' : '' %>>
                                <span class="custom-switch-indicator"></span>
                              </label>
                              <input type="hidden" name="rpTransferEnabled" id="rpTransferEnabledInput"
                                value="<%= settings.rpTransferEnabled ? 'true' : 'false' %>">
                            </div>

                            <div class="settings-field">
                              <label class="settings-field__label" for="rpTransferSuspendedMessage">Suspension Notice Message</label>
                              <p class="settings-field__desc">Shown to users when RP transfer is disabled.</p>
                              <textarea name="rpTransferSuspendedMessage" id="rpTransferSuspendedMessage"
                                class="form-control" rows="3" maxlength="500"
                                placeholder="e.g. RP transfer has been suspended for the time being. Please check back later."
                              ><%= settings.rpTransferSuspendedMessage %></textarea>
                              <small class="text-muted"><span id="charCount"><%= settings.rpTransferSuspendedMessage.length %></span> / 500</small>
                            </div>

                          </div>
                        </div>
                      </div>

                      <div class="settings-divider"></div>

                      <!-- ── Maintenance ─────────────────────────────────────── -->
                      <div class="settings-group" id="group-maintenance">
                        <button type="button" class="settings-group__header" data-target="body-maintenance">
                          <div class="settings-group__title">
                            <span class="settings-group__icon settings-group__icon--orange">
                              <i data-feather="tool"></i>
                            </span>
                            <div>
                              <span class="settings-group__label">Maintenance</span>
                              <span class="settings-group__sub">Control site availability and scheduled downtime</span>
                            </div>
                          </div>
                          <div class="settings-group__meta">
                            <span class="settings-badge <%= settings.maintenanceModeEnabled ? 'settings-badge--warn' : 'settings-badge--on' %>" id="badge-maint">
                              <%= settings.maintenanceModeEnabled ? 'Active' : 'Off' %>
                            </span>
                            <i data-feather="chevron-down" class="settings-group__chevron"></i>
                          </div>
                        </button>
                        <div class="settings-group__body" id="body-maintenance">
                          <div class="settings-group__inner">

                            <!-- Sub-section: Maintenance Mode -->
                            <p class="settings-subsection-label">Maintenance Mode</p>

                            <div class="settings-row">
                              <div class="settings-row__text">
                                <span class="settings-row__label">Enable Maintenance Mode</span>
                                <span class="settings-row__desc">All public pages will display the maintenance screen. The admin panel stays accessible.</span>
                              </div>
                              <label class="custom-switch mb-0">
                                <input type="checkbox" id="maintModeToggle" class="custom-switch-input"
                                  <%= settings.maintenanceModeEnabled ? 'checked' : '' %>>
                                <span class="custom-switch-indicator"></span>
                              </label>
                              <input type="hidden" name="maintenanceModeEnabled" id="maintModeEnabledInput"
                                value="<%= settings.maintenanceModeEnabled ? 'true' : 'false' %>">
                            </div>

                            <div class="settings-field">
                              <label class="settings-field__label" for="maintenanceMessage">Maintenance Page Message</label>
                              <p class="settings-field__desc">Displayed on the maintenance screen shown to users.</p>
                              <textarea name="maintenanceMessage" id="maintenanceMessage"
                                class="form-control" rows="3" maxlength="600"
                                placeholder="e.g. We're performing scheduled maintenance. We'll be back shortly."
                              ><%= settings.maintenanceMessage %></textarea>
                              <small class="text-muted"><span id="maintMsgCount"><%= settings.maintenanceMessage.length %></span> / 600</small>
                            </div>

                            <div class="settings-sub-divider"></div>

                            <!-- Sub-section: Schedule Maintenance -->
                            <p class="settings-subsection-label">Schedule Maintenance</p>

                            <div class="settings-row">
                              <div class="settings-row__text">
                                <span class="settings-row__label">Show Countdown Banner</span>
                                <span class="settings-row__desc">Displays a countdown banner at the top of every public page until the scheduled time.</span>
                              </div>
                              <label class="custom-switch mb-0">
                                <input type="checkbox" id="maintBannerToggle" class="custom-switch-input"
                                  <%= settings.maintenanceBannerEnabled ? 'checked' : '' %>>
                                <span class="custom-switch-indicator"></span>
                              </label>
                              <input type="hidden" name="maintenanceBannerEnabled" id="maintBannerEnabledInput"
                                value="<%= settings.maintenanceBannerEnabled ? 'true' : 'false' %>">
                            </div>

                            <div class="settings-field mb-0">
                              <label class="settings-field__label" for="maintenanceBannerScheduledAt">Scheduled Maintenance Time</label>
                              <p class="settings-field__desc">The countdown banner will run until this date and time.</p>
                              <input type="datetime-local" name="maintenanceBannerScheduledAt"
                                id="maintenanceBannerScheduledAt" class="form-control"
                                style="max-width:280px;"
                                value="<%= settings.maintenanceBannerScheduledAt ? new Date(settings.maintenanceBannerScheduledAt).toISOString().slice(0,16) : '' %>">
                            </div>

                          </div>
                        </div>
                      </div>

                    </div>
                    <div class="card-footer text-right">
                      <button type="button" class="btn btn-primary px-4" id="saveSettingsBtn">
                        <i class="fa fa-save mr-1"></i> Save Settings
                      </button>
                    </div>
                  </div>

                </form>
              </div>
            </div>
          </div>
        </section>

        <div class="settingSidebar">
          <a href="javascript:void(0)" class="settingPanelToggle"><i class="fa fa-spin fa-cog"></i></a>
          <div class="settingSidebar-body ps-container ps-theme-default">
            <div class="fade show active">
              <div class="setting-panel-header">Setting Panel</div>
              <div class="p-15 border-bottom">
                <h6 class="font-medium m-b-10">Select Layout</h6>
                <div class="selectgroup layout-color w-50">
                  <label class="selectgroup-item">
                    <input type="radio" name="value" value="1" class="selectgroup-input-radio select-layout" checked>
                    <span class="selectgroup-button">Light</span>
                  </label>
                  <label class="selectgroup-item">
                    <input type="radio" name="value" value="2" class="selectgroup-input-radio select-layout">
                    <span class="selectgroup-button">Dark</span>
                  </label>
                </div>
              </div>
              <div class="mt-4 mb-4 p-3 align-center rt-sidebar-last-ele">
                <a href="#" class="btn btn-icon icon-left btn-primary btn-restore-theme">
                  <i class="fas fa-undo"></i> Restore Default
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>

      <footer class="main-footer">
        <div class="footer-left">&copy; <%= new Date().getFullYear() %> Kabacu. All rights reserved.</div>
        <div class="footer-right"></div>
      </footer>
    </div>
  </div>

<style>
/* ── Accordion groups ─────────────────────────────────────────────────────── */
.settings-group__header {
  width: 100%; display: flex; align-items: center;
  justify-content: space-between; gap: 12px;
  padding: 18px 24px; background: none; border: none;
  cursor: pointer; text-align: left;
  transition: background .15s;
}
.settings-group__header:hover { background: #f9fafb; }

.settings-group__title {
  display: flex; align-items: center; gap: 14px;
}
.settings-group__icon {
  width: 38px; height: 38px; border-radius: 10px; flex-shrink: 0;
  display: flex; align-items: center; justify-content: center;
}
.settings-group__icon svg { width: 18px; height: 18px; }
.settings-group__icon--blue   { background: #eff6ff; color: #3b82f6; }
.settings-group__icon--orange { background: #fff7ed; color: #f97316; }

.settings-group__label { display: block; font-size: 14px; font-weight: 700; color: #111827; }
.settings-group__sub   { display: block; font-size: 12px; color: #9ca3af; margin-top: 1px; }

.settings-group__meta {
  display: flex; align-items: center; gap: 12px; flex-shrink: 0;
}
.settings-group__chevron {
  width: 18px; height: 18px; color: #9ca3af;
  transition: transform .25s cubic-bezier(.4,0,.2,1);
  flex-shrink: 0;
}
.settings-group.is-open .settings-group__chevron {
  transform: rotate(180deg);
}

/* Status badges */
.settings-badge {
  display: inline-block; font-size: 11px; font-weight: 700;
  padding: 3px 10px; border-radius: 20px; letter-spacing: .3px;
}
.settings-badge--on   { background: #dcfce7; color: #16a34a; }
.settings-badge--off  { background: #f3f4f6; color: #6b7280; }
.settings-badge--warn { background: #fef3c7; color: #d97706; }

/* Collapsible body */
.settings-group__body {
  overflow: hidden;
  max-height: 0;
  transition: max-height .3s cubic-bezier(.4,0,.2,1);
}
.settings-group.is-open .settings-group__body {
  max-height: 800px;
}
.settings-group__inner {
  padding: 4px 24px 24px;
  border-top: 1px solid #f3f4f6;
}

/* Row: label + toggle */
.settings-row {
  display: flex; align-items: center; justify-content: space-between;
  gap: 16px; padding: 16px 0;
  border-bottom: 1px solid #f9fafb;
}
.settings-row:last-of-type { border-bottom: none; }
.settings-row__text { flex: 1; min-width: 0; }
.settings-row__label { display: block; font-size: 13px; font-weight: 600; color: #374151; }
.settings-row__desc  { display: block; font-size: 12px; color: #9ca3af; margin-top: 2px; line-height: 1.5; }

/* Field: label + input/textarea */
.settings-field { padding-top: 16px; }
.settings-field__label { font-size: 13px; font-weight: 600; color: #374151; margin-bottom: 4px; display: block; }
.settings-field__desc  { font-size: 12px; color: #9ca3af; margin-bottom: 8px; }

/* Dividers */
.settings-divider     { height: 1px; background: #f3f4f6; }
.settings-sub-divider { height: 1px; background: #f3f4f6; margin: 20px 0 16px; }

/* Sub-section label */
.settings-subsection-label {
  font-size: 11px; font-weight: 700; text-transform: uppercase;
  letter-spacing: .8px; color: #9ca3af; margin: 16px 0 4px;
}
</style>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
// ── Accordion ────────────────────────────────────────────────────────────────
document.querySelectorAll('.settings-group__header').forEach(function (btn) {
  btn.addEventListener('click', function () {
    var group = this.closest('.settings-group');
    var isOpen = group.classList.contains('is-open');
    // Close all
    document.querySelectorAll('.settings-group').forEach(function (g) {
      g.classList.remove('is-open');
    });
    // Open clicked (unless it was already open)
    if (!isOpen) group.classList.add('is-open');
  });
});

// Auto-open the maintenance group when maintenance mode is active
<% if (settings.maintenanceModeEnabled) { %>
document.getElementById('group-maintenance').classList.add('is-open');
<% } %>

// ── Hidden-input sync for toggles ────────────────────────────────────────────
function syncToggle(checkboxId, hiddenId, badgeId, labels) {
  var cb  = document.getElementById(checkboxId);
  var hid = document.getElementById(hiddenId);
  var bdg = badgeId ? document.getElementById(badgeId) : null;
  if (!cb || !hid) return;
  cb.addEventListener('change', function () {
    hid.value = this.checked ? 'true' : 'false';
    if (bdg && labels) {
      bdg.textContent = this.checked ? labels[0] : labels[1];
      bdg.className = 'settings-badge ' + (this.checked ? labels[2] : labels[3]);
    }
  });
}
syncToggle('rpTransferToggle',  'rpTransferEnabledInput', 'badge-rp',    ['Enabled',  'Disabled', 'settings-badge--on',   'settings-badge--off']);
syncToggle('maintModeToggle',   'maintModeEnabledInput',  'badge-maint', ['Active',   'Off',      'settings-badge--warn', 'settings-badge--on']);
syncToggle('maintBannerToggle', 'maintBannerEnabledInput', null, null);

// ── Character counters ───────────────────────────────────────────────────────
document.getElementById('rpTransferSuspendedMessage').addEventListener('input', function () {
  document.getElementById('charCount').textContent = this.value.length;
});
document.getElementById('maintenanceMessage').addEventListener('input', function () {
  document.getElementById('maintMsgCount').textContent = this.value.length;
});

// ── Save confirmation ────────────────────────────────────────────────────────
document.getElementById('saveSettingsBtn').addEventListener('click', function () {
  Swal.fire({
    title: 'Save Settings?',
    text: 'Changes will apply to the live site immediately.',
    icon: 'question',
    showCancelButton: true,
    confirmButtonText: 'Yes, Save',
    confirmButtonColor: '#47c363',
    cancelButtonText: 'Cancel',
  }).then(function (result) {
    if (result.isConfirmed) document.getElementById('settingsForm').submit();
  });
});
</script>
