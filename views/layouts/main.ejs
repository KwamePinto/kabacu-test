<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Data Mall — CTC</title>
  <link rel="shortcut icon" type="image/x-icon" href="/assets/images/new.PNG">

  <!-- Google Fonts: Inter -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">

  <!-- SweetAlert2 -->
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

  <!-- Lucide Icons -->
  <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.js"></script>

  <!-- Design System CSS -->
  <link rel="stylesheet" href="/assets/css/new/base.css">
  <link rel="stylesheet" href="/assets/css/new/layout.css">
  <link rel="stylesheet" href="/assets/css/new/components.css">
  <link rel="stylesheet" href="/assets/css/new/home.css">
  <link rel="stylesheet" href="/assets/css/new/auth.css">
  <link rel="stylesheet" href="/assets/css/new/data-category.css">
  <link rel="stylesheet" href="/assets/css/new/wallet.css">
  <link rel="stylesheet" href="/assets/css/new/history.css">
  <link rel="stylesheet" href="/assets/css/new/profile.css">
  <link rel="stylesheet" href="/assets/css/new/checkout.css">
</head>
<body class="<% if (locals.hideHeader) { %>no-header<% } %>">

  <% if (!locals.hideHeader) { %>
  <%- include('../partials/header') %>
  <% } %>

  <main class="page-main">
    <%- body %>
  </main>

  <% if (!locals.hideFooter) { %>
  <%- include('../partials/footer') %>
  <% } %>

  <% if (!locals.hideFooter) { %>
  <!-- Bottom Navigation (mobile only) -->
  <nav class="bottom-nav" id="bottomNav">
    <a href="/" class="bottom-nav__item" data-path="/">
      <i data-lucide="home"></i>
      <span>Home</span>
    </a>
    <a href="/history" class="bottom-nav__item" data-path="/history">
      <i data-lucide="package"></i>
      <span>My Order</span>
    </a>
    <button type="button" class="bottom-nav__item" id="supportNavBtn">
      <i data-lucide="message-circle"></i>
      <span>Support</span>
    </button>
    <a href="/user-profile" class="bottom-nav__item" data-path="/user-profile">
      <i data-lucide="user"></i>
      <span>My Account</span>
    </a>
  </nav>

  <!-- Support bottom sheet (mobile) -->
  <div id="supportSheet" class="support-sheet" aria-hidden="true">
    <div class="support-sheet__backdrop" id="supportSheetBackdrop"></div>
    <div class="support-sheet__panel">
      <div class="support-sheet__handle"></div>
      <h4 class="support-sheet__title">Help &amp; Support</h4>

      <a href="/faq" class="support-sheet__option">
        <div class="support-sheet__opt-icon support-sheet__opt-icon--faq">
          <i data-lucide="help-circle"></i>
        </div>
        <div class="support-sheet__opt-text">
          <div class="support-sheet__opt-title">FAQs</div>
          <div class="support-sheet__opt-sub">Browse common questions &amp; answers</div>
        </div>
        <i data-lucide="chevron-right" class="support-sheet__opt-arrow"></i>
      </a>

      <button type="button" class="support-sheet__option" id="liveChatSheetBtn">
        <div class="support-sheet__opt-icon support-sheet__opt-icon--chat">
          <i data-lucide="message-circle"></i>
        </div>
        <div class="support-sheet__opt-text">
          <div class="support-sheet__opt-title">Live Chat</div>
          <div class="support-sheet__opt-sub">Chat with our support team</div>
        </div>
        <i data-lucide="chevron-right" class="support-sheet__opt-arrow"></i>
      </button>
    </div>
  </div>

  <style>
  .support-sheet {
    position: fixed; inset: 0; z-index: 200;
    pointer-events: none; visibility: hidden;
  }
  .support-sheet.open {
    pointer-events: auto; visibility: visible;
  }
  .support-sheet__backdrop {
    position: absolute; inset: 0;
    background: rgba(0,0,0,.45);
    opacity: 0; transition: opacity .25s;
  }
  .support-sheet.open .support-sheet__backdrop { opacity: 1; }

  .support-sheet__panel {
    position: absolute; bottom: 0; left: 0; right: 0;
    background: var(--white);
    border-radius: 18px 18px 0 0;
    padding: 12px 20px 36px;
    transform: translateY(100%);
    transition: transform .3s cubic-bezier(.32,0,.15,1);
  }
  .support-sheet.open .support-sheet__panel { transform: translateY(0); }

  .support-sheet__handle {
    width: 36px; height: 4px;
    border-radius: 2px; background: var(--border);
    margin: 0 auto 16px;
  }
  .support-sheet__title {
    font-size: 15px; font-weight: 800;
    color: var(--text); margin-bottom: 16px;
  }

  .support-sheet__option {
    display: flex; align-items: center; gap: 14px;
    width: 100%; padding: 14px 12px;
    background: none; border: none; cursor: pointer;
    border-radius: 10px; text-decoration: none;
    transition: background .15s; color: inherit;
  }
  .support-sheet__option:hover,
  .support-sheet__option:active { background: var(--primary-light); }
  .support-sheet__option + .support-sheet__option { margin-top: 4px; }

  .support-sheet__opt-icon {
    width: 42px; height: 42px; flex-shrink: 0;
    border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
  }
  .support-sheet__opt-icon svg { width: 20px; height: 20px; }
  .support-sheet__opt-icon--faq  { background: var(--primary-light); color: var(--primary); }
  .support-sheet__opt-icon--chat { background: #e8f4ff; color: #2563eb; }

  .support-sheet__opt-text { flex: 1; text-align: left; }
  .support-sheet__opt-title { font-size: 14px; font-weight: 700; color: var(--text); }
  .support-sheet__opt-sub   { font-size: 12px; color: var(--muted); margin-top: 2px; }

  .support-sheet__opt-arrow { width: 16px; height: 16px; color: var(--muted); flex-shrink: 0; }
  </style>

  <!-- Claim RP Modal -->
  <% if (user) { %>
  <div id="claimRpModal" class="claim-rp-modal">
    <div class="claim-rp-modal__box">
      <h4 class="modal-title" style="margin-bottom:6px;">Reward Points</h4>
      <p class="modal-subtitle">Your accumulated RP balance</p>
      <div class="claim-rp-modal__amount">
        <%= user?.rpBalance || 0 %> <span class="claim-rp-modal__unit">RP</span>
      </div>
      <div class="modal-actions">
        <button id="confirmClaimBtn" class="btn btn--primary btn--full">
          <i data-lucide="check"></i>
          Confirm Claim
        </button>
        <button id="closeClaimModal" class="btn btn--ghost btn--full">Cancel</button>
      </div>
    </div>
  </div>
  <% } %>
  <% } %>

  <!-- Lucide icons render -->
  <script>lucide.createIcons();</script>

  <!-- Dynamic island scroll behaviour -->
  <script>
    (function() {
      var header = document.querySelector('.app-header');
      var lastY  = window.scrollY;

      if (!header) return;

      window.addEventListener('scroll', function() {
        var currentY = window.scrollY;

        if (currentY > lastY) {
          /* scrolling DOWN — hide */
          header.classList.add('island-hidden');
        } else {
          /* scrolling UP — show */
          header.classList.remove('island-hidden');
        }

        lastY = currentY;
      }, { passive: true });
    })();
  </script>

  <!-- Bottom nav active state -->
  <script>
    (function() {
      const path = window.location.pathname;
      document.querySelectorAll('.bottom-nav__item').forEach(function(item) {
        const p = item.getAttribute('data-path');
        if (p === '/' ? path === '/' : path.startsWith(p)) {
          item.classList.add('active');
        }
      });
    })();
  </script>

  <!-- Search bar logic -->
  <script>
    (function() {
      const searchBtn   = document.getElementById('searchBtn');
      const searchRow   = document.getElementById('headerSearchRow');
      const searchInput = document.getElementById('headerSearchInput');
      const clearBtn    = document.getElementById('clearSearchBtn');

      if (!searchBtn || !searchRow || !searchInput) return;

      function openSearch() {
        searchRow.classList.add('open');
        lucide.createIcons();
        searchInput.focus();
      }

      function closeSearch() {
        searchRow.classList.remove('open');
        searchInput.value = '';
        if (clearBtn) clearBtn.classList.remove('visible');
        showAll();
      }

      function showAll() {
        document.querySelectorAll('.product-card, .bundle-card').forEach(function(c) {
          c.style.display = '';
        });
        const nr = document.getElementById('searchNoResults');
        if (nr) nr.style.display = 'none';
      }

      searchBtn.addEventListener('click', openSearch);

      /* X button clears text only — does not close the overlay */
      if (clearBtn) {
        clearBtn.addEventListener('click', function() {
          searchInput.value = '';
          clearBtn.classList.remove('visible');
          showAll();
        });
      }

      /* Back arrow closes the overlay */
      var closeSearchBtn = document.getElementById('closeSearchBtn');
      if (closeSearchBtn) closeSearchBtn.addEventListener('click', closeSearch);

      searchInput.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') closeSearch();
      });

      searchInput.addEventListener('input', function() {
        const q = this.value.toLowerCase().trim();
        if (clearBtn) clearBtn.classList.toggle('visible', q.length > 0);

        const cards = document.querySelectorAll('.product-card, .bundle-card');
        let visible = 0;
        cards.forEach(function(card) {
          const name  = (
            card.getAttribute('data-name') ||
            card.querySelector('.product-card__name, .bundle-card__name')?.textContent || ''
          ).toLowerCase();
          const brand = (
            card.getAttribute('data-brand') ||
            card.querySelector('.product-card__brand, .bundle-card__network')?.textContent || ''
          ).toLowerCase();
          const match = !q || name.includes(q) || brand.includes(q);
          card.style.display = match ? '' : 'none';
          if (match) visible++;
        });

        const nr = document.getElementById('searchNoResults');
        if (nr) nr.style.display = (q && visible === 0) ? 'block' : 'none';
      });
    })();
  </script>

  <!-- Claim RP -->
  <script>
    const claimModal      = document.getElementById('claimRpModal');
    const openClaimBtn    = document.getElementById('openClaimModal');
    const closeClaimBtn   = document.getElementById('closeClaimModal');
    const confirmClaimBtn = document.getElementById('confirmClaimBtn');

    if (openClaimBtn)  openClaimBtn.addEventListener('click',  function(e) { e.preventDefault(); claimModal.classList.add('open'); });
    if (closeClaimBtn) closeClaimBtn.addEventListener('click', function()   { claimModal.classList.remove('open'); });
    if (claimModal)    claimModal.addEventListener('click',    function(e)  { if (e.target === claimModal) claimModal.classList.remove('open'); });

    if (confirmClaimBtn) {
      confirmClaimBtn.addEventListener('click', async function() {
        try {
          confirmClaimBtn.disabled = true;
          confirmClaimBtn.textContent = 'Processing...';
          const res  = await fetch('/wallet/claim-rp', { method: 'POST', headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': '<%= csrfToken %>' } });
          const data = await res.json();
          if (data.success) {
            Swal.fire({ icon: 'success', text: data.message });
            setTimeout(() => location.reload(), 1500);
          } else {
            Swal.fire({ icon: 'error', text: data.message });
            confirmClaimBtn.disabled = false;
            confirmClaimBtn.textContent = 'Confirm Claim';
          }
        } catch (e) {
          Swal.fire({ icon: 'error', text: 'Claim failed' });
          confirmClaimBtn.disabled = false;
          confirmClaimBtn.textContent = 'Confirm Claim';
        }
      });
    }
  </script>

  <!-- Desktop nav: mark active link based on current path -->
  <script>
    (function() {
      var path = window.location.pathname;
      document.querySelectorAll('.desktop-nav__link').forEach(function(link) {
        var href = link.getAttribute('href');
        if (!href) return;
        if ((href === '/' && path === '/') || (href !== '/' && path.startsWith(href))) {
          link.classList.add('active');
        }
      });
    })();
  </script>

  <!-- Support bottom sheet logic -->
  <script>
    (function() {
      var sheet        = document.getElementById('supportSheet');
      var backdrop     = document.getElementById('supportSheetBackdrop');
      var supportBtn   = document.getElementById('supportNavBtn');
      var liveChatBtn  = document.getElementById('liveChatSheetBtn');

      if (!sheet) return;

      function openSheet()  { sheet.classList.add('open');    lucide.createIcons(); }
      function closeSheet() { sheet.classList.remove('open'); }

      if (supportBtn)  supportBtn.addEventListener('click', openSheet);
      if (backdrop)    backdrop.addEventListener('click',   closeSheet);

      if (liveChatBtn) {
        liveChatBtn.addEventListener('click', function() {
          closeSheet();
          if (typeof Tawk_API !== 'undefined' && typeof Tawk_API.maximize === 'function') {
            Tawk_API.maximize();
          }
        });
      }
    })();
  </script>

  <!-- Page transition — fade out on navigate, fade in on load -->
  <script>
    (function() {
      document.addEventListener('click', function(e) {
        var link = e.target.closest('a[href]');
        if (!link) return;
        var href = link.getAttribute('href');
        if (!href) return;
        /* skip anchors, special protocols, new-tab links, downloads */
        var ch = href.charAt(0);
        if (ch === '#' || href.indexOf('javascript') === 0 ||
            href.indexOf('mailto:') === 0 || href.indexOf('tel:') === 0) return;
        if (link.target === '_blank' || link.hasAttribute('download')) return;
        /* skip cross-origin */
        try {
          var url = new URL(href, window.location.href);
          if (url.origin !== window.location.origin) return;
        } catch (err) { return; }
        e.preventDefault();
        document.body.classList.add('is-leaving');
        var dest = href;
        setTimeout(function() { window.location.href = dest; }, 200);
      });
    })();
  </script>

  <!-- Tawk.to live chat -->
  <% if (!locals.hideFooter) { %>
  <script type="text/javascript">
    var Tawk_API=Tawk_API||{}, Tawk_LoadStart=new Date();
    (function(){
    var s1=document.createElement("script"),s0=document.getElementsByTagName("script")[0];
    s1.async=true;
    s1.src='https://embed.tawk.to/6a3ea848bf47421d4a0c9fe3/1js2c2msl';
    s1.charset='UTF-8';
    s1.setAttribute('crossorigin','*');
    s0.parentNode.insertBefore(s1,s0);
    })();
  </script>
  <% } %>


  <!-- Flash messages (success / error from server) -->
  <script>
    (function() {
      var sm = <%- JSON.stringify(success_msg) %>;
      var em = <%- JSON.stringify(error_msg) %>;
      if (sm && sm.length > 0) Swal.fire({ icon: 'success', title: 'Success', text: sm[0], timer: 3000, showConfirmButton: false });
      if (em && em.length > 0) Swal.fire({ icon: 'error',   title: 'Error',   text: em[0] });
    })();
  </script>
</body>
</html>
